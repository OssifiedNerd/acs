        XOffset = self.UIPosition.X.Offset,
        YScale = self.UIPosition.Y.Scale,
        YOffset = self.UIPosition.Y.Offset,
    }

    local success, result = pcall(self.HttpService.JSONEncode, self.HttpService, settings)
    if success then
        writefile(self.SettingsFile, result)
    end
end

function MultiGrinder:LoadSettings()
    if not isfile(self.SettingsFile) then return end
    
    local success, jsonData = pcall(readfile, self.SettingsFile)
    if not success then return end
    
    local success, settings = pcall(self.HttpService.JSONDecode, self.HttpService, jsonData)
    if not success or typeof(settings) ~= "table" then return end

    self.CombatToolName = settings.CombatToolName or self.CombatToolName
    self.CombatTargetNames = settings.CombatTargetNames or self.CombatTargetNames
    self.CombatPriorityAreaScanRadius = settings.CombatPriorityAreaScanRadius or self.CombatPriorityAreaScanRadius
    self.CombatPriorityAreaScanTime = settings.CombatPriorityAreaScanTime or self.CombatPriorityAreaScanTime
    self.PriorityAreaEnabled = settings.PriorityAreaEnabled or self.PriorityAreaEnabled
    
    if settings.MiningToolNames and typeof(settings.MiningToolNames) == "table" then
        for i = 1, 4 do
            self.MiningToolNames[i] = settings.MiningToolNames[i] or ""
        end
    end
    
    self.MiningTargetNames = settings.MiningTargetNames or self.MiningTargetNames
    self.MiningPriorityAreaScanRadius = settings.MiningPriorityAreaScanRadius or self.MiningPriorityAreaScanRadius
    self.MiningPriorityAreaScanTime = settings.MiningPriorityAreaScanTime or self.MiningPriorityAreaScanTime
    self.MiningPriorityAreaEnabled = settings.MiningPriorityAreaEnabled or self.MiningPriorityAreaEnabled
    
    self.AutoIgnoreEnabled = settings.AutoIgnoreEnabled ~= false
    self.TeleportOnRespawnEnabled = settings.TeleportOnRespawnEnabled ~= false
    self.AutoBlockEnabled = settings.AutoBlockEnabled == true
    self.SpecialAttackEnabled = settings.SpecialAttackEnabled == true
    
    self.SafeDistanceEnabled = settings.SafeDistanceEnabled == true
    self.CombatSafeDistance = settings.CombatSafeDistance or 10
    self.MiningSafeDistance = settings.MiningSafeDistance or 1
    self.MiningHitboxMode = settings.MiningHitboxMode == true
    
    self.HeightOffsetEnabled = settings.HeightOffsetEnabled == true
    self.CombatHeightOffset = settings.CombatHeightOffset or CONFIG.CombatHeightOffset
    self.MiningHeightOffset = settings.MiningHeightOffset or CONFIG.MiningHeightOffset
    self.MoneyFarmEnabled = settings.MoneyFarmEnabled == true
    
    if settings.MoneyFarmTeleportLocation then
        self.MoneyFarmTeleportLocation = CFrame.new(unpack(settings.MoneyFarmTeleportLocation))
    end
    
    self.FlySpeed = settings.FlySpeed or CONFIG.FlySpeed
    self.SellerItemName = settings.SellerItemName or self.SellerItemName
    self.SellerAmount = settings.SellerAmount or self.SellerAmount
    self.SellerCooldown = settings.SellerCooldown or self.SellerCooldown
    
    self.EventStartKeyword = settings.EventStartKeyword or ""
    self.EventEndKeyword = settings.EventEndKeyword or ""
    self.EventTargetNames = settings.EventTargetNames or self.EventTargetNames
    self.EventPriorityAreaEnabled = settings.EventPriorityAreaEnabled == true
    self.EventPriorityAreaScanRadius = settings.EventPriorityAreaScanRadius or 50
    self.EventPriorityAreaScanTime = settings.EventPriorityAreaScanTime or 3
    
    if settings.NoclipEnabled then
        task.delay(1, function()
            self:ToggleNoclip(true)
            self:updateGUI()
        end)
    end
    if settings.FlyEnabled then
        task.delay(1, function()
            self:ToggleFly(true)
            self:updateGUI()
        end)
    end
    if settings.MoneyFarmEnabled then
        task.delay(1, function()
            self:StartMoneyFarm()
            self:updateGUI()
        end)
    end

    if settings.PriorityAreas then
        self.PriorityAreas = {}
        for _, components in ipairs(settings.PriorityAreas) do
            table.insert(self.PriorityAreas, CFrame.new(unpack(components)))
        end
    end
    
    if settings.MiningPriorityAreas then
        self.MiningPriorityAreas = {}
        for _, components in ipairs(settings.MiningPriorityAreas) do
            table.insert(self.MiningPriorityAreas, CFrame.new(unpack(components)))
        end
    end
    
    if settings.EventPriorityAreas then
        self.EventPriorityAreas = {}
        for _, components in ipairs(settings.EventPriorityAreas) do
            table.insert(self.EventPriorityAreas, CFrame.new(unpack(components)))
        end
    end

    if settings.UIPos then
        self.UIPosition = UDim2.new(
            settings.UIPos.XScale or 0.5,
            settings.UIPos.XOffset or -CONFIG.FrameWidth/2,
            settings.UIPos.YScale or 0.5,
            settings.UIPos.YOffset or -((CONFIG.TitleBarHeight + CONFIG.TabBarHeight + CONFIG.ContentAreaHeight) / 2)
        )
    end
end

