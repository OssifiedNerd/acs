local function getRemotes()
    local remotes = {}
    local success, err = pcall(function()
        local clientRemotes = ReplicatedStorage:WaitForChild("ClientRemotes", 5)
        remotes.EquipItem = clientRemotes:WaitForChild("Inventory"):WaitForChild("EquipItem", 5)
        remotes.UseItem = clientRemotes:WaitForChild("Character"):WaitForChild("UseItem", 5)
        remotes.Block = clientRemotes:WaitForChild("Character"):WaitForChild("Block", 5)
        remotes.DialogEvent = clientRemotes:WaitForChild("Character"):WaitForChild("DialogEvent", 5)
    end)
    
    if not success then
        warn("[Multi-Bot] Failed to get remotes: " .. tostring(err))
    end
    
    return remotes
end

-- NEW: Sell Remote Finder
local function getSellRemote()
    local remote = nil
    local success = pcall(function()
        local clientRemotes = ReplicatedStorage:WaitForChild("ClientRemotes", 5)
        remote = clientRemotes:WaitForChild("Inventory"):WaitForChild("SellItem", 3)
    end)
    if not success or not remote then
        for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
            if (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) and string.find(string.lower(obj.Name), "sell") then
                remote = obj
                break
            end
        end
    end
    return remote
end

