local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualInputManager = game:GetService("VirtualInputManager")
local RunService = game:GetService("RunService")

local Fisher = {}
Fisher.__index = Fisher

-- CONFIGURATION
local CONFIG = {
    RodName = "Golden Fishing Rod", -- Change to your rod name
    UseItemRemote = ReplicatedStorage:WaitForChild("ClientRemotes"):WaitForChild("Character"):WaitForChild("UseItem"),
    
    -- UI Detection
    FishingGuiName = "FishingGui", -- You may need to adjust this
    FishContainerName = "FishContainer", -- Adjust based on actual UI structure
    TimerLabelName = "Timer",
    
    -- Timing
    CastCooldown = 2, -- Seconds between casts
    ClickDelay = 0.05, -- Delay between fish clicks
}

function Fisher:new()
    local self = setmetatable({
        Enabled = false,
        IsFishing = false,
        CurrentGui = nil,
        LoopThread = nil,
    }, Fisher)
    
    return self
end

function Fisher:getRod()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild(CONFIG.RodName)
end

function Fisher:castRod()
    local rod = self:getRod()
    if not rod then
        warn("[Fisher] Rod not found: " .. CONFIG.RodName)
        return false
    end
    
    local success = pcall(function()
        CONFIG.UseItemRemote:FireServer(rod, false)
    end)
    
    if success then
        print("[Fisher] Casted rod")
        return true
    else
        warn("[Fisher] Failed to cast")
        return false
    end
end

-- Detect fishing minigame GUI
function Fisher:findFishingGui()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    
    -- Common patterns - adjust these based on actual game UI
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") then
            -- Check if this looks like the fishing UI
            -- You need to inspect the actual game to get the correct names
            if gui.Name:lower():find("fish") or gui.Name:lower():find("minigame") then
                return gui
            end
            
            -- Check descendants for fish-like elements
            for _, child in ipairs(gui:GetDescendants()) do
                if child.Name:lower():find("fish") and child:IsA("GuiObject") then
                    return gui
                end
            end
        end
    end
    
    return nil
end

-- Extract fish data from the GUI
function Fisher:parseFish(gui)
    local fishList = {}
    
    -- This is where you need to inspect the actual UI structure
    -- The screenshot shows fish with numbers on them
    -- They are likely TextButtons or ImageButtons with TextLabels for numbers
    
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("TextButton") or obj:IsA("ImageButton") then
            -- Look for number indicator
            local numberLabel = obj:FindFirstChild("Number") or obj:FindFirstChild("Order")
            local number = nil
            
            if numberLabel and numberLabel:IsA("TextLabel") then
                number = tonumber(numberLabel.Text)
            elseif obj:IsA("TextButton") and tonumber(obj.Text) then
                -- The button itself might have the number
                number = tonumber(obj.Text)
            end
            
            -- Alternative: check for TextLabels inside the fish that contain numbers
            if not number then
                for _, child in ipairs(obj:GetDescendants()) do
                    if child:IsA("TextLabel") then
                        local num = tonumber(child.Text)
                        if num then
                            number = num
                            break
                        end
                    end
                end
            end
            
            if number then
                table.insert(fishList, {
                    Button = obj,
                    Number = number,
                    Position = obj.AbsolutePosition,
                    Size = obj.AbsoluteSize
                })
            end
        end
    end
    
    -- Sort by number (click order)
    table.sort(fishList, function(a, b)
        return a.Number < b.Number
    end)
    
    return fishList
end

-- Click a GUI element using VirtualInputManager (no cursor movement needed visually, but VIM simulates at screen coords)
function Fisher:clickGuiElement(element)
    if not element or not element.Visible then return false end
    
    local pos = element.AbsolutePosition
    local size = element.AbsoluteSize
    local center = pos + (size / 2)
    
    -- Method 1: VirtualInputManager (simulates real mouse at screen position)
    -- This doesn't move your actual cursor but fires at those screen coordinates
    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
    task.wait(0.01)
    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
    
    -- Method 2: Fire the click event directly (more stealthy but may not work if game validates input source)
    -- pcall(function()
    --     element.MouseButton1Click:Fire()
    -- end)
    
    return true
end

-- Alternative: Fire click signals directly
function Fisher:clickGuiElementDirect(element)
    if not element then return false end
    pcall(function()
        -- Try multiple event types that games might listen to
        if element:IsA("TextButton") or element:IsA("ImageButton") then
            element.MouseButton1Down:Fire()
            task.wait(0.01)
            element.MouseButton1Up:Fire()
            element.MouseButton1Click:Fire()
        end
    end)
    return true
end

-- Complete the minigame
function Fisher:solveMinigame(gui)
    print("[Fisher] Solving minigame...")
    
    local fishList = self:parseFish(gui)
    print("[Fisher] Found " .. #fishList .. " fish to click")
    
    if #fishList == 0 then
        warn("[Fisher] No fish found in GUI!")
        -- Debug: print all descendants
        for _, obj in ipairs(gui:GetDescendants()) do
            print("  -", obj.ClassName, obj.Name, obj:IsA("GuiObject") and "Visible:" .. tostring(obj.Visible) or "")
        end
        return false
    end
    
    -- Click each fish in order
    for i, fish in ipairs(fishList) do
        print("[Fisher] Clicking fish #" .. fish.Number)
        
        -- Try both methods
        self:clickGuiElement(fish.Button)
        -- self:clickGuiElementDirect(fish.Button)
        
        task.wait(CONFIG.ClickDelay)
    end
    
    print("[Fisher] Minigame completed")
    return true
end

-- Main loop
function Fisher:start()
    self.Enabled = true
    print("[Fisher] Started")
    
    self.LoopThread = task.spawn(function()
        while self.Enabled do
            if not self.IsFishing then
                self.IsFishing = true
                
                -- Step 1: Cast rod
                if self:castRod() then
                    -- Step 2: Wait for minigame to appear
                    local gui = nil
                    local waitStart = tick()
                    
                    while tick() - waitStart < 10 do -- Max 10s wait
                        gui = self:findFishingGui()
                        if gui then break end
                        task.wait(0.1)
                    end
                    
                    if gui then
                        -- Step 3: Solve minigame
                        self.CurrentGui = gui
                        self:solveMinigame(gui)
                        
                        -- Wait for GUI to close
                        while gui and gui.Parent do
                            task.wait(0.1)
                        end
                    else
                        warn("[Fisher] No fishing GUI appeared")
                    end
                end
                
                self.IsFishing = false
                task.wait(CONFIG.CastCooldown)
            else
                task.wait(0.1)
            end
        end
    end)
end

function Fisher:stop()
    self.Enabled = false
    if self.LoopThread then
        task.cancel(self.LoopThread)
        self.LoopThread = nil
    end
    print("[Fisher] Stopped")
end

-- DEBUG MODE: Use this to inspect the actual UI structure
function Fisher:inspectGui()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    
    print("=== INSPECTING PLAYER GUI ===")
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") then
            print("\nScreenGui:", gui.Name)
            self:inspectDescendants(gui, 0)
        end
    end
end

function Fisher:inspectDescendants(parent, depth)
    local indent = string.rep("  ", depth)
    for _, child in ipairs(parent:GetChildren()) do
        local info = indent .. child.ClassName .. " | " .. child.Name
        if child:IsA("GuiObject") then
            info = info .. " | Visible: " .. tostring(child.Visible)
            info = info .. " | Pos: " .. tostring(child.AbsolutePosition)
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                info = info .. " | Text: '" .. child.Text .. "'"
            end
        end
        print(info)
        
        if depth < 3 then -- Limit depth
            self:inspectDescendants(child, depth + 1)
        end
    end
end

