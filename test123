function MultiGrinder:setMinimizedState(isMinimized)
    self.IsMinimized = isMinimized
    
    if not self.MainGui or not self.MainGui.MainFrame then return end

    local MainFrame = self.MainGui.MainFrame
    local ContentContainer = MainFrame:FindFirstChild("ContentContainer")
    local TabBar = MainFrame:FindFirstChild("TabBar")
    
    if not ContentContainer or not TabBar then return end
    
    ContentContainer.Visible = not isMinimized
    TabBar.Visible = not isMinimized
    
    if isMinimized then
        MainFrame:TweenSize(UDim2.new(0, CONFIG.FrameWidth, 0, CONFIG.TitleBarHeight), "Out", "Quad", 0.2, true)
    else
        MainFrame:TweenSize(UDim2.new(0, CONFIG.FrameWidth, 0, self.InitialFrameHeight), "Out", "Quad", 0.2, true)
    end
end

function MultiGrinder:updateGUI()
    if not self.MainGui then return end
    
    local generalPage = self.MainGui.GeneralPage
    local combatPage = self.MainGui.CombatPage
    local miningPage = self.MainGui.MiningPage
    
    if self.Enabled then
        generalPage.ToggleButton.Text = "ON"
        generalPage.ToggleButton.BackgroundColor3 = CONFIG.ToggleOnColor
        generalPage.IgnoreButton.Visible = true
    else
        generalPage.ToggleButton.Text = "OFF"
        generalPage.ToggleButton.BackgroundColor3 = CONFIG.ToggleOffColor
        generalPage.IgnoreButton.Visible = false
    end
    
    if self.Enabled then
        if self.CurrentTargetIdentifier then
            generalPage.IgnoreButton.Text = string.format("IGNORE: %s", self.CurrentTargetIdentifier.Name)
            generalPage.IgnoreButton.BackgroundColor3 = Color3.fromRGB(150, 0, 200)
        else
            generalPage.IgnoreButton.Text = "No Target to Ignore"
            generalPage.IgnoreButton.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        end
    end

    generalPage.AutoIgnoreButton.Text = self.AutoIgnoreEnabled and "10s Auto-Ignore: ON" or "10s Auto-Ignore: OFF"
    generalPage.AutoIgnoreButton.BackgroundColor3 = self.AutoIgnoreEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor

    generalPage.TeleportOnRespawnButton.Text = self.TeleportOnRespawnEnabled and "TP on Respawn: ON" or "TP on Respawn: OFF"
    generalPage.TeleportOnRespawnButton.BackgroundColor3 = self.TeleportOnRespawnEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor

    generalPage.AutoBlockButton.Text = self.AutoBlockEnabled and "Auto-Block: ON" or "Auto-Block: OFF"
    generalPage.AutoBlockButton.BackgroundColor3 = self.AutoBlockEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    
    generalPage.SpecialAttackButton.Text = self.SpecialAttackEnabled and "SPECIAL ATTACK: ON" or "SPECIAL ATTACK: OFF"
    generalPage.SpecialAttackButton.BackgroundColor3 = self.SpecialAttackEnabled and CONFIG.SpecialAttackColor or CONFIG.ToggleOffColor
    
    -- ADDED: Distance UI updates
    generalPage.SafeDistanceToggle.Text = self.SafeDistanceEnabled and "Safe Distance: ON" or "Safe Distance: OFF"
    generalPage.SafeDistanceToggle.BackgroundColor3 = self.SafeDistanceEnabled and CONFIG.DistanceColor or CONFIG.ToggleOffColor
    
    generalPage.MiningHitboxToggle.Text = self.MiningHitboxMode and "Mining Hitbox+: ON" or "Mining Hitbox+: OFF"
    generalPage.MiningHitboxToggle.BackgroundColor3 = self.MiningHitboxMode and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor

    local currentToolName = (self.Mode == "Combat") and self.CombatToolName or self.MiningToolName
    local modeDisplayName = (self.Mode == "Combat") and "Attacking" or "Mining"
    generalPage.ModeButton.Text = modeDisplayName .. " ("..currentToolName..")"
    
    combatPage.PriorityAreaToggleButton.Text = self.PriorityAreaEnabled and "Priority Areas: ON" or "Priority Areas: OFF"
    combatPage.PriorityAreaToggleButton.BackgroundColor3 = self.PriorityAreaEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    combatPage.PriorityAreaCountLabel.Text = string.format("Areas: %d", #self.PriorityAreas)

    miningPage.MiningPriorityAreaToggleButton.Text = self.MiningPriorityAreaEnabled and "Priority Areas: ON" or "Priority Areas: OFF"
    miningPage.MiningPriorityAreaToggleButton.BackgroundColor3 = self.MiningPriorityAreaEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    miningPage.MiningPriorityAreaCountLabel.Text = string.format("Areas: %d", #self.MiningPriorityAreas)

    for tabName, tabButton in pairs(self.MainGui.Tabs) do
        if tabName == self.CurrentTab then
            tabButton.BackgroundColor3 = CONFIG.BackgroundColor 
            tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            tabButton.BackgroundColor3 = CONFIG.TabBarColor 
            tabButton.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end
end

function MultiGrinder:showTab(tabName)
    self.CurrentTab = tabName
    self:updateGUI()
    
    local contentContainer = self.MainGui.MainFrame:FindFirstChild("ContentContainer")
    if not contentContainer then return end

    for _, page in pairs(contentContainer:GetChildren()) do
        if page:IsA("Frame") and page.Name:match("Page$") then
            page.Visible = false
        end
    end
    
    if self.MainGui.Pages[tabName] then
        self.MainGui.Pages[tabName].Visible = true
        task.wait()
        local layout = self.MainGui.Pages[tabName]:FindFirstChildOfClass("UIListLayout")
        if layout then
            contentContainer.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
        end
        contentContainer.CanvasPosition = Vector2.new(0,0)
    end
end

