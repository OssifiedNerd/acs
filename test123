        self.AutoBlockEnabled = not self.AutoBlockEnabled
        BlockBtn.Text = self.AutoBlockEnabled and "AUTO-BLOCK: ON" or "AUTO-BLOCK: OFF"
        BlockBtn.BackgroundColor3 = self.AutoBlockEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
        if not self.AutoBlockEnabled then self:handleBlock(false) end
    end)

