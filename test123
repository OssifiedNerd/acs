    local self = setmetatable({
        Enabled = false,
        IsFishing = false,
        CurrentGui = nil,
        LoopThread = nil,
        MainGui = nil,
        CurrentTab = "Main",
        Remotes = getRemotes(),

        -- Stats
        CastsTotal = 0,
