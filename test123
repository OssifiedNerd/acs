local function getRemotes()
    local clientRemotes = ReplicatedStorage:WaitForChild("ClientRemotes", 5)
    local charRemotes = clientRemotes and clientRemotes:WaitForChild("Character", 5)
    local invRemotes = clientRemotes and clientRemotes:WaitForChild("Inventory", 5)
    
