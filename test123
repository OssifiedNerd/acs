-- ==================== UI MANAGEMENT ====================

function StudlandsFisher:showTab(tabName)
    self.CurrentTab = tabName
    self:updateGUI()

    local contentContainer = self.MainGui.MainFrame:FindFirstChild("ContentContainer")
    if not contentContainer then return end

    for _, page in pairs(contentContainer:GetChildren()) do
        if page:IsA("Frame") and page.Name:match("Page$") then
            page.Visible = false
        end
    end

    if self.MainGui.Pages[tabName] then
        self.MainGui.Pages[tabName].Visible = true
        task.wait()
        local layout = self.MainGui.Pages[tabName]:FindFirstChildOfClass("UIListLayout")
        if layout then
            contentContainer.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
        end
        contentContainer.CanvasPosition = Vector2.new(0, 0)
    end
end

function StudlandsFisher:setMinimizedState(isMinimized)
    self.IsMinimized = isMinimized
    if not self.MainGui or not self.MainGui.MainFrame then return end

    local MainFrame = self.MainGui.MainFrame
    local ContentContainer = MainFrame:FindFirstChild("ContentContainer")
    local TabBar = MainFrame:FindFirstChild("TabBar")

    if not ContentContainer or not TabBar then return end

    ContentContainer.Visible = not isMinimized
    TabBar.Visible = not isMinimized

    if isMinimized then
        MainFrame:TweenSize(UDim2.new(0, CONFIG.FrameWidth, 0, CONFIG.TitleBarHeight), "Out", "Quad", 0.2, true)
    else
        MainFrame:TweenSize(UDim2.new(0, CONFIG.FrameWidth, 0, self.InitialFrameHeight), "Out", "Quad", 0.2, true)
    end

    self.MainGui.MinimizeButton.Text = isMinimized and "+" or "−"
end

function StudlandsFisher:updateGUI()
    if not self.MainGui then return end

    local main = self.MainGui.MainPage
    local settings = self.MainGui.SettingsPage

    if self.Enabled then
        main.ToggleButton.Text = "FISHER: ON"
        main.ToggleButton.BackgroundColor3 = CONFIG.ToggleOnColor
    else
        main.ToggleButton.Text = "FISHER: OFF"
        main.ToggleButton.BackgroundColor3 = CONFIG.ToggleOffColor
    end

    main.AutoCastButton.Text = self.AutoCastEnabled and "Auto Cast: ON" or "Auto Cast: OFF"
    main.AutoCastButton.BackgroundColor3 = self.AutoCastEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor

    main.AutoSolveButton.Text = self.AutoSolveEnabled and "Auto Solve: ON" or "Auto Solve: OFF"
    main.AutoSolveButton.BackgroundColor3 = self.AutoSolveEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor

    settings.ClickMethodButton.Text = "Method: " .. self.ClickMethod
    settings.ClickMethodButton.BackgroundColor3 = self.ClickMethod == "VIM" and CONFIG.AccentColor or CONFIG.InfoColor

    settings.StopOnFailButton.Text = self.StopOnFail and "Stop On Fail: ON" or "Stop On Fail: OFF"
    settings.StopOnFailButton.BackgroundColor3 = self.StopOnFail and CONFIG.ToggleOffColor or CONFIG.ToggleOffColor

    settings.DebugModeButton.Text = self.DebugMode and "Debug Mode: ON" or "Debug Mode: OFF"
    settings.DebugModeButton.BackgroundColor3 = self.DebugMode and CONFIG.WarningColor or CONFIG.ToggleOffColor

    for tabName, tabButton in pairs(self.MainGui.Tabs) do
        if tabName == self.CurrentTab then
            tabButton.BackgroundColor3 = CONFIG.BackgroundColor
            tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            tabButton.Font = Enum.Font.GothamBold
        else
            tabButton.BackgroundColor3 = CONFIG.TabBarColor
            tabButton.TextColor3 = Color3.fromRGB(150, 150, 150)
            tabButton.Font = Enum.Font.Gotham
        end
    end
end

