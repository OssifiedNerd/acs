    }, StudlandsFisher)

    self.InitialFrameHeight = CONFIG.TitleBarHeight + CONFIG.TabBarHeight + CONFIG.ContentAreaHeight
    self:setupGUI()
    return self
end

-- ==================== CORE FISHING LOGIC ====================

function StudlandsFisher:equipRod(rodName)
    if not self.Remotes.EquipItem then
        self:log("EquipItem remote not found", "error")
        return false
    end

    local success = pcall(function()
        self.Remotes.EquipItem:InvokeServer(rodName)
    end)

    if success then
        self:log("Equipped: " .. rodName, "success")
        return true
    else
        self:log("Failed to equip: " .. rodName, "error")
        return false
    end
end

function StudlandsFisher:getRod()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild(CONFIG.RodName)
end

function StudlandsFisher:castRod()
    local rod = self:getRod()
    if not rod then
        self:log("Rod not found in character: " .. CONFIG.RodName, "error")
        self:log("Make sure rod is equipped or enable Auto Equip", "warning")
        return false
    end

    if not self.Remotes.UseItem then
        self:log("UseItem remote not found", "error")
        return false
    end

    local success = pcall(function()
        self.Remotes.UseItem:FireServer(rod, false)
    end)

    if success then
        self.CastsTotal = self.CastsTotal + 1
        self:log("Casted rod", "info")
        self:updateStats()
        return true
    else
        self.CastsFailed = self.CastsFailed + 1
        self:log("Failed to cast rod", "error")
        self:updateStats()
        return false
    end
end

function StudlandsFisher:findFishingGui()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")

    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui.Enabled then
            local nameLower = gui.Name:lower()
            for _, pattern in ipairs(CONFIG.FishingGuiPatterns) do
                if nameLower:find(pattern:lower()) then
                    return gui
                end
            end

            for _, child in ipairs(gui:GetDescendants()) do
                if child:IsA("GuiObject") and child.Visible then
                    local childName = child.Name:lower()
                    for _, pattern in ipairs(CONFIG.FishButtonPatterns) do
                        if childName:find(pattern:lower()) then
                            return gui
                        end
                    end
                end
            end
        end
    end
    return nil
end

function StudlandsFisher:parseFish(gui)
    local fishList = {}

    for _, obj in ipairs(gui:GetDescendants()) do
        if (obj:IsA("TextButton") or obj:IsA("ImageButton")) and obj.Visible then
            local number = nil

            if obj:IsA("TextButton") then
                number = tonumber(obj.Text)
            end

            if not number then
                local numChild = obj:FindFirstChild("Number") or obj:FindFirstChild("Order") or obj:FindFirstChild("Index")
                if numChild and numChild:IsA("TextLabel") then
                    number = tonumber(numChild.Text)
                end
            end

            if not number then
                for _, child in ipairs(obj:GetDescendants()) do
                    if child:IsA("TextLabel") and child.Visible then
                        local num = tonumber(child.Text)
                        if num then
                            number = num
                            break
                        end
                    end
                end
            end

            if not number then
                local nameNum = obj.Name:match("%d+")
                if nameNum then
                    number = tonumber(nameNum)
                end
            end

            if number then
                table.insert(fishList, {
                    Button = obj,
                    Number = number,
                    Position = obj.AbsolutePosition,
                    Size = obj.AbsoluteSize
                })
            end
        end
    end

    table.sort(fishList, function(a, b)
        return a.Number < b.Number
    end)

    return fishList
end

function StudlandsFisher:clickElement(element)
    if not element or not element.Visible then return false end

    local pos = element.AbsolutePosition
    local size = element.AbsoluteSize
    local center = pos + (size / 2)

    if self.ClickMethod == "VIM" then
        VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
        task.wait(0.01)
        VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
    else
        pcall(function()
            element.MouseButton1Down:Fire()
            task.wait(0.01)
            element.MouseButton1Up:Fire()
            element.MouseButton1Click:Fire()
        end)
    end

    return true
end

function StudlandsFisher:solveMinigame(gui)
    if not self.AutoSolveEnabled then
        self:log("Auto-solve disabled, waiting for manual input", "warning")
        return false
    end

    self:log("Solving minigame...", "info")

    local fishList = self:parseFish(gui)

    if #fishList == 0 then
        self:log("No fish found in GUI!", "error")
        if self.DebugMode then
            self:inspectGuiDetailed(gui)
        end
        return false
    end

    self:log("Found " .. #fishList .. " fish to click", "info")

    for i, fish in ipairs(fishList) do
        self:clickElement(fish.Button)
        self.FishClickedTotal = self.FishClickedTotal + 1
        task.wait(CONFIG.ClickDelay)
    end

    self.CastsSuccess = self.CastsSuccess + 1
    self:log("Minigame completed", "success")
    self:updateStats()
    return true
end

-- ==================== MAIN LOOP ====================

function StudlandsFisher:fishingLoop()
    while self.Enabled do
        if not self.IsFishing and self.AutoCastEnabled then
            self.IsFishing = true

            if self:castRod() then
                local gui = nil
                local waitStart = tick()

                while tick() - waitStart < CONFIG.MaxWaitTime do
                    gui = self:findFishingGui()
                    if gui then break end
                    task.wait(0.1)
                end

                if gui then
                    self.CurrentGui = gui
                    task.wait(0.2)

                    local success = self:solveMinigame(gui)

                    if not success and self.StopOnFail then
                        self:log("Stopping due to failure", "error")
                        self.Enabled = false
                        self:updateGUI()
                        break
                    end

                    local closeStart = tick()
                    while gui and gui.Parent and tick() - closeStart < 5 do
                        task.wait(0.1)
                    end
                else
                    self:log("No fishing GUI appeared", "warning")
                end
            end

            self.IsFishing = false
            task.wait(CONFIG.CastCooldown)
        else
            task.wait(0.1)
        end
    end

    self.IsFishing = false
    self:log("Fishing loop stopped", "info")
end

-- ==================== DEBUG / INSPECTOR ====================

function StudlandsFisher:inspectGui()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    self:log("=== INSPECTING GUI ===", "info")

    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") then
            self:log("ScreenGui: " .. gui.Name .. " | Enabled: " .. tostring(gui.Enabled), "info")
        end
    end
end

function StudlandsFisher:inspectGuiDetailed(gui)
    self:log("=== DETAILED GUI DUMP ===", "info")
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("GuiObject") then
            local text = ""
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                text = " | Text: '" .. obj.Text .. "'"
            end
            self:log(obj.ClassName .. " | " .. obj.Name .. " | Visible: " .. tostring(obj.Visible) .. text, "info")
        end
    end
end

-- ==================== LOGGING ====================

function StudlandsFisher:log(message, level)
    level = level or "info"
    local timestamp = os.date("%H:%M:%S")
    local entry = "[" .. timestamp .. "] [" .. level:upper() .. "] " .. message

    table.insert(self.Logs, 1, {text = entry, level = level})

    if #self.Logs > self.MaxLogs then
        table.remove(self.Logs)
    end

    if self.MainGui and self.MainGui.LogsPage and self.MainGui.LogsPage.LogText then
        self:updateLogDisplay()
    end

    print("[Fisher] " .. entry)
end

function StudlandsFisher:updateLogDisplay()
    local logText = ""
    for i = math.min(20, #self.Logs), 1, -1 do
        logText = logText .. self.Logs[i].text .. "\n"
    end
    self.MainGui.LogsPage.LogText.Text = logText
end

-- ==================== STATS ====================

function StudlandsFisher:updateStats()
    if not self.MainGui then return end

    local runtime = self.StartTime and (tick() - self.StartTime) or 0
    local hours = math.floor(runtime / 3600)
    local mins = math.floor((runtime % 3600) / 60)
    local secs = math.floor(runtime % 60)

    local stats = self.MainGui.MainPage
    stats.CastsLabel.Text = "Casts: " .. self.CastsTotal
    stats.SuccessLabel.Text = "Success: " .. self.CastsSuccess
    stats.FailedLabel.Text = "Failed: " .. self.CastsFailed
    stats.FishClickedLabel.Text = "Fish Clicked: " .. self.FishClickedTotal
    stats.RuntimeLabel.Text = string.format("Runtime: %02d:%02d:%02d", hours, mins, secs)

    local rate = 0
    if self.CastsTotal > 0 then
        rate = math.floor((self.CastsSuccess / self.CastsTotal) * 100)
    end
    stats.SuccessRateLabel.Text = "Success Rate: " .. rate .. "%"
end

