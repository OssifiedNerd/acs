        CombatHeightOffset = self.CombatHeightOffset,
        MiningHeightOffset = self.MiningHeightOffset,
        MoneyFarmEnabled = self.MoneyFarmEnabled,
        MoneyFarmTeleportLocation = self.MoneyFarmTeleportLocation and {self.MoneyFarmTeleportLocation:GetComponents()} or nil,
        FlySpeed = self.FlySpeed,
        SellerItemName = self.SellerItemName,
        SellerAmount = self.SellerAmount,
        SellerCooldown = self.SellerCooldown,
        EventStartKeyword = self.EventStartKeyword,
        EventEndKeyword = self.EventEndKeyword,
        EventTargetNames = self.EventTargetNames,
        EventPriorityAreaEnabled = self.EventPriorityAreaEnabled,
        EventPriorityAreaScanRadius = self.EventPriorityAreaScanRadius,
        EventPriorityAreaScanTime = self.EventPriorityAreaScanTime,
        PriorityAreas = {},
        MiningPriorityAreas = {},
        EventPriorityAreas = {},
        UIPos = {}
    }

    for _, cf in ipairs(self.PriorityAreas) do
        table.insert(settings.PriorityAreas, {cf:GetComponents()})
    end
    
    for _, cf in ipairs(self.MiningPriorityAreas) do
        table.insert(settings.MiningPriorityAreas, {cf:GetComponents()})
    end
    
    for _, cf in ipairs(self.EventPriorityAreas) do
        table.insert(settings.EventPriorityAreas, {cf:GetComponents()})
    end

