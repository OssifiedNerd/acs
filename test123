-- [[ UTILITY SENSORS ]]
function MultiGrinder:getHumanoidRootPart()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

function MultiGrinder:getTargetNames(mode)
    local targetString = (mode == "Combat") and self.CombatTargetNames or self.MiningTargetNames
    local names = {}
    for name in string.gmatch(targetString, "[^,]+") do
        names[#names + 1] = name:gsub("^%s*(.-)%s*$", "%1")
    end
    return names
end

function MultiGrinder:findClosestTarget(position, names)
    local closestTargetPart = nil 
    local closestTargetKey = nil 
    local minDistance = math.huge

    for _, obj in ipairs(Workspace:GetDescendants()) do
        for _, name in ipairs(names) do
            if string.lower(obj.Name) == string.lower(name) then 
                local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChild("HumanoidRootPart")
                local targetKey = obj -- Default key
                
                if targetPart then 
                    local parentModel = targetPart.Parent
                    local humanoid = parentModel:FindFirstChildOfClass("Humanoid")
                    targetKey = humanoid and parentModel or targetPart
                end

                if targetPart and not self.IgnoredTargets[targetKey] then
                    local dist = (targetPart.Position - position).Magnitude
                    if dist < minDistance then
                        minDistance = dist
                        closestTargetPart = targetPart 
                        closestTargetKey = targetKey 
                    end
                end
            end
        end
    end
    return closestTargetPart, closestTargetKey
end

-- [[ FIXED ATTACK & BLOCK LOGIC (YOUR CODES) ]]
function MultiGrinder:equipTool(toolName)
    local char = LocalPlayer.Character
    if not char or not self.Remotes.EquipItem then return false end
    
    local toolInChar = char:FindFirstChild(toolName)
    if toolInChar then return true end

    local args = { [1] = toolName }
    local success = pcall(function()
        self.Remotes.EquipItem:InvokeServer(unpack(args))
    end)
    
    return success and char:WaitForChild(toolName, 1.5) ~= nil
end

function MultiGrinder:simulateAction(toolName)
    local char = LocalPlayer.Character
    if not char or not self.Remotes.UseItem then return end
    
    local toolInstance = char:FindFirstChild(toolName)
    if toolInstance then
        -- Integrated your working attack snippet logic
        local args = {
            [1] = toolInstance,
            [2] = false,
            [5] = 1.1039999771118163
        }
        self.Remotes.UseItem:FireServer(unpack(args))
    end
end

function MultiGrinder:handleBlock(state)
    if not self.Remotes.Block then return end
    -- Integrated your working block snippet logic
    local args = { [1] = state }
    self.Remotes.Block:FireServer(unpack(args))
end

-- [[ PRIORITY AREA SCANNING LOGIC ]]
function MultiGrinder:findClosestMobInArea(position, radius)
    local closest, key, dist = nil, nil, math.huge
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local hum = obj:IsA("Humanoid") and obj or nil
        if hum and hum.Health > 0 and obj.Parent ~= LocalPlayer.Character then
            local hrp = obj.Parent:FindFirstChild("HumanoidRootPart")
            if hrp and not self.IgnoredTargets[obj.Parent] then
                local d = (hrp.Position - position).Magnitude
                if d <= radius and d < dist then
                    dist = d
                    closest, key = hrp, obj.Parent
                end
            end
        end
    end
    return closest, key
end

-- [[ AUTOMATION EXECUTION ]]
function MultiGrinder:executeCombatAction(hrp)
    -- Handle Priority Areas first if enabled
    if self.PriorityAreaEnabled and #self.PriorityAreas > 0 then
        local currentAreaCF = self.PriorityAreas[self.CurrentPriorityAreaIndex]
        if not currentAreaCF then return end
        
        local target, key = self:findClosestMobInArea(currentAreaCF.p, self.CombatPriorityAreaScanRadius)
        if target then
            if self:equipTool(self.CombatToolName) then
                hrp.CFrame = target.CFrame * CFrame.new(CONFIG.Combat.TeleportOffset)
                self:simulateAction(self.CombatToolName)
            end
            return
        else
            -- Cycle areas if nothing found
            hrp.CFrame = currentAreaCF
            self.PriorityAreaScanTimer = self.PriorityAreaScanTimer + CONFIG.FarmSpeed
            if self.PriorityAreaScanTimer >= self.CombatPriorityAreaScanTime then
                self.PriorityAreaScanTimer = 0
                self.CurrentPriorityAreaIndex = (self.CurrentPriorityAreaIndex % #self.PriorityAreas) + 1
            end
        end
        return
    end

    -- Normal Farm
    local target, key = self:findClosestTarget(hrp.Position, self:getTargetNames("Combat"))
    if target then
        if self:equipTool(self.CombatToolName) then
            hrp.CFrame = target.CFrame * CFrame.new(CONFIG.Combat.TeleportOffset)
            self:simulateAction(self.CombatToolName)
        end
    end
end

-- [[ DATA PERSISTENCE ]]
function MultiGrinder:SaveSettings()
    local data = {
        CombatToolName = self.CombatToolName,
        CombatTargetNames = self.CombatTargetNames,
        AutoBlockEnabled = self.AutoBlockEnabled,
        AutoIgnoreEnabled = self.AutoIgnoreEnabled,
        PriorityAreaEnabled = self.PriorityAreaEnabled,
        UIPos = {self.MainGui.MainFrame.Position.X.Offset, self.MainGui.MainFrame.Position.Y.Offset}
    }
    local success, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if success then writefile(self.SettingsFile, encoded) end
end

function MultiGrinder:LoadSettings()
    if not isfile(self.SettingsFile) then return end
    local success, decoded = pcall(function() return HttpService:JSONDecode(readfile(self.SettingsFile)) end)
    if success then
        self.CombatToolName = decoded.CombatToolName or self.CombatToolName
        self.AutoBlockEnabled = decoded.AutoBlockEnabled or false
        if decoded.UIPos then self.UIPosition = UDim2.new(0.5, decoded.UIPos[1], 0.5, decoded.UIPos[2]) end
    end
end

