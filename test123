    TabBar.Size = UDim2.new(1,0,0, CONFIG.TabBarHeight)
    TabBar.BackgroundColor3 = CONFIG.TabBarColor

    -- Functional Buttons
    local function createBtn(txt, color, call)
        local b = Instance.new("TextButton", ContentContainer)
        b.Size = UDim2.new(0.9, 0, 0, 35)
        b.Text = txt
        b.BackgroundColor3 = color
        b.TextColor3 = Color3.new(1,1,1)
        b.Font = Enum.Font.GothamMedium
        b.MouseButton1Click:Connect(call)
        return b
    end

    local ToggleBtn = createBtn("AUTO-FARM: OFF", CONFIG.ToggleOffColor, function()
        self.Enabled = not self.Enabled
        ToggleBtn.Text = self.Enabled and "AUTO-FARM: ON" or "AUTO-FARM: OFF"
        ToggleBtn.BackgroundColor3 = self.Enabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    end)

