end

-- NEW: Tool Warning Detection
function MultiGrinder:SetupToolWarningDetection()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local startupTime = tick()
    
    local function checkWarning(obj)
        if not (obj:IsA("TextLabel") or obj:IsA("TextButton")) then return end
        
        local function handle()
            if tick() - startupTime < 2 then return end -- Grace period on load
            if string.find(obj.Text, "You need a better or different tool") then
                self:HandleToolWarning()
            end
        end
        
        handle()
        obj:GetPropertyChangedSignal("Text"):Connect(handle)
        obj:GetPropertyChangedSignal("Visible"):Connect(function()
            if obj.Visible then handle() end
        end)
    end
    
    for _, desc in ipairs(playerGui:GetDescendants()) do
        checkWarning(desc)
    end
    
    playerGui.DescendantAdded:Connect(checkWarning)
end

function MultiGrinder:HandleToolWarning()
    if tick() - self.LastToolWarningTime < 0.8 then return end
    self.LastToolWarningTime = tick()
    
    if self.Mode ~= "Mining" then return end
    
    local nextIndex = self.CurrentMiningToolIndex + 1
    while nextIndex <= 4 do
        local toolName = self.MiningToolNames[nextIndex]
        if toolName and toolName ~= "" then
            break
        end
        nextIndex = nextIndex + 1
    end
    
    if nextIndex > 4 then
        print("[Multi-Bot] No valid tool found for target, ignoring.")
        if self.CurrentTargetIdentifier then
            self.IgnoredTargets[self.CurrentTargetIdentifier] = true
        end
        self.CurrentTarget = nil
        self.CurrentTargetIdentifier = nil
        self.CurrentMiningToolIndex = 1
        self.EquippedToolName = nil
        restoreCamera(self)
        self:updateGUI()
    else
        self.CurrentMiningToolIndex = nextIndex
        self.EquippedToolName = nil -- Force re-equip next loop
        print("[Multi-Bot] Tool warning detected, switching to:", self.MiningToolNames[nextIndex])
    end
end

-- NEW: Chat Detection for Events
function MultiGrinder:SetupChatDetection()
    local success = pcall(function()
        local TextChatService = game:GetService("TextChatService")
        
        local function hookChannel(channel)
            if not channel:IsA("TextChannel") then return end
            channel.MessageReceived:Connect(function(textChatMessage)
                local text = textChatMessage.Text or ""
                if self.EventStartKeyword ~= "" and string.find(text, self.EventStartKeyword) then
                    task.spawn(function() self:StartEventMode() end)
                end
                if self.EventEndKeyword ~= "" and string.find(text, self.EventEndKeyword) then
                    task.spawn(function() self:EndEventMode() end)
                end
            end)
        end
        
        for _, channel in ipairs(TextChatService.TextChannels:GetChildren()) do
            hookChannel(channel)
        end
        
        TextChatService.TextChannels.ChildAdded:Connect(hookChannel)
    end)
    
    if not success then
        warn("[Multi-Bot] TextChatService detection failed, trying legacy...")
        local Players = game:GetService("Players")
        Players.PlayerChatted:Connect(function(player, message)
            if self.EventStartKeyword ~= "" and string.find(message, self.EventStartKeyword) then
                self:StartEventMode()
            end
            if self.EventEndKeyword ~= "" and string.find(message, self.EventEndKeyword) then
                self:EndEventMode()
            end
        end)
    end
end

-- NEW: Event Mode Control
function MultiGrinder:StartEventMode()
    if self.EventMode then return end
    print("[Multi-Bot] Event started! Switching to event mode.")
    
    self.PreEventState = {
        Mode = self.Mode,
        Enabled = self.Enabled,
        PriorityAreaEnabled = self.PriorityAreaEnabled,
        MiningPriorityAreaEnabled = self.MiningPriorityAreaEnabled,
        MoneyFarmEnabled = self.MoneyFarmEnabled,
        SellerEnabled = self.SellerEnabled,
    }
    
    -- Pause other systems
    if self.MoneyFarmEnabled then
        self:StopMoneyFarm()
    end
    if self.SellerEnabled then
        self:StopSelling()
    end
    
    self.EventMode = true
    self.Mode = "Combat"
    self.Enabled = true
    self.PriorityAreaEnabled = false
    self.MiningPriorityAreaEnabled = false
    
    self.CurrentEventAreaIndex = 1
    self.EventAreaScanTimer = 0
    self.EventAreaTarget = nil
    self.CurrentTarget = nil
    self.CurrentTargetIdentifier = nil
    self.TargetAcquiredTime = nil
    self.LastMiningAngle = 0
    restoreCamera(self)
    self:updateGUI()
end

function MultiGrinder:EndEventMode()
    if not self.EventMode then return end
    print("[Multi-Bot] Event ended! Restoring previous mode.")
    
    self.EventMode = false
    self.Mode = self.PreEventState.Mode or "Combat"
    self.Enabled = self.PreEventState.Enabled or false
    self.PriorityAreaEnabled = self.PreEventState.PriorityAreaEnabled or false
    self.MiningPriorityAreaEnabled = self.PreEventState.MiningPriorityAreaEnabled or false
    
    -- Restore other systems
    if self.PreEventState.MoneyFarmEnabled then
        self:StartMoneyFarm()
    end
    if self.PreEventState.SellerEnabled then
        self:StartSelling()
    end
    
    self.EventAreaTarget = nil
    self.EventAreaScanTimer = 0
    self.CurrentEventAreaIndex = 1
    self.CurrentTarget = nil
    self.CurrentTargetIdentifier = nil
    self.TargetAcquiredTime = nil
    restoreCamera(self)
    self:updateGUI()
end

function MultiGrinder:StartSpecialAttack()
    if self.SpecialAttackThread then return end
    
    self.SpecialAttackThread = task.spawn(function()
        while self.SpecialAttackEnabled do
            local success, err = pcall(function()
                local char = LocalPlayer.Character
                if not char then return end
                
                local toolName = (self.Mode == "Combat") and self.CombatToolName or self.MiningToolNames[1]
                local tool = char:FindFirstChild(toolName)
                
                if tool and self.Remotes.UseItem then
                    local args = {
                        [1] = tool,
                        [2] = true,
                        [5] = 1.1039999771118163
                    }
                    self.Remotes.UseItem:FireServer(unpack(args))
                end
            end)
            
            if not success then
                warn("[Multi-Bot] Special attack error: " .. tostring(err))
            end
            
            task.wait(CONFIG.SpecialAttackCooldown)
        end
        
        self.SpecialAttackThread = nil
    end)
end

function MultiGrinder:StopSpecialAttack()
    self.SpecialAttackEnabled = false
end

-- MONEY FARM FUNCTIONALITY
function MultiGrinder:StartMoneyFarm()
    if self.MoneyFarmConnection then return end
    
    if self.MoneyFarmTeleportLocation then
        local hrp = self:getHumanoidRootPart()
        if hrp then
            hrp.CFrame = self.MoneyFarmTeleportLocation
        end
    end
    
    self.MoneyFarmLastReset = tick()
    
    self.MoneyFarmConnection = RunService.Heartbeat:Connect(function()
        local success, err = pcall(function()
            if not self.Remotes.DialogEvent then return end
            
            local args = {
                [1] = workspace.NPCs:FindFirstChild("Blacksmith Cubey"),
                [2] = "StartQuest",
                [3] = {
                    ["QuestName"] = "Find Blacksmith's Crystal"
                }
            }
            
            if args[1] then
                self.Remotes.DialogEvent:FireServer(unpack(args))
            end
        end)
        
        if not success then
            warn("[Multi-Bot] Money Farm error: " .. tostring(err))
        end
    end)
    
    -- 30 minute auto-reset loop
    self.MoneyFarmResetThread = task.spawn(function()
        while self.MoneyFarmEnabled do
            task.wait(1)
            if not self.MoneyFarmEnabled then break end
            if tick() - self.MoneyFarmLastReset >= self.MoneyFarmResetInterval then
                self.MoneyFarmLastReset = tick()
                local char = LocalPlayer.Character
                if char then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        hum.Health = 0
                    end
                end
            end
        end
    end)
end

function MultiGrinder:StopMoneyFarm()
    if self.MoneyFarmConnection then
        self.MoneyFarmConnection:Disconnect()
        self.MoneyFarmConnection = nil
    end
    if self.MoneyFarmResetThread then
        task.cancel(self.MoneyFarmResetThread)
        self.MoneyFarmResetThread = nil
    end
end

-- SELLER FUNCTIONALITY
function MultiGrinder:StartSelling()
    if self.SellerThread then return end
    
    self.SellerThread = task.spawn(function()
        while self.SellerEnabled do
            local success, err = pcall(function()
                if not self.SellRemote then
                    self.SellRemote = getSellRemote()
                    if not self.SellRemote then return end
                end
                
                local args = {
                    [1] = self.SellerItemName,
                    [2] = self.SellerAmount
                }
                
                if self.SellRemote:IsA("RemoteFunction") then
                    self.SellRemote:InvokeServer(unpack(args))
                else
                    self.SellRemote:FireServer(unpack(args))
                end
                
                self.TotalSold = self.TotalSold + self.SellerAmount
            end)
            
            if not success then
                warn("[Multi-Bot] Sell error: " .. tostring(err))
                task.wait(0.5)
            else
                task.wait(self.SellerCooldown)
            end
        end
        
        self.SellerThread = nil
    end)
end

function MultiGrinder:StopSelling()
    self.SellerEnabled = false
    if self.SellerThread then
        task.cancel(self.SellerThread)
        self.SellerThread = nil
    end
end

-- NOCLIP FUNCTIONALITY
function MultiGrinder:ToggleNoclip(enabled)
    self.NoclipEnabled = enabled
    
    if enabled then
        self.NoclipConnection = RunService.Stepped:Connect(function()
            if not self.NoclipEnabled then return end
            local char = LocalPlayer.Character
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        if self.NoclipConnection then
            self.NoclipConnection:Disconnect()
            self.NoclipConnection = nil
        end
        local char = LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end
end

-- FLY FUNCTIONALITY
function MultiGrinder:ToggleFly(enabled)
    self.FlyEnabled = enabled
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if enabled then
        self.FlyBodyGyro = Instance.new("BodyGyro")
        self.FlyBodyGyro.P = 9e4
        self.FlyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        self.FlyBodyGyro.CFrame = hrp.CFrame
        self.FlyBodyGyro.Parent = hrp
        
        self.FlyBodyVelocity = Instance.new("BodyVelocity")
        self.FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        self.FlyBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        self.FlyBodyVelocity.Parent = hrp
        
        task.spawn(function()
            while self.FlyEnabled and self.FlyBodyGyro and self.FlyBodyVelocity do
                local currentCamera = Workspace.CurrentCamera
                local moveDirection = Vector3.new(0, 0, 0)
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                    moveDirection = moveDirection + currentCamera.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                    moveDirection = moveDirection - currentCamera.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                    moveDirection = moveDirection - currentCamera.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                    moveDirection = moveDirection + currentCamera.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    moveDirection = moveDirection + Vector3.new(0, 1, 0)
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                    moveDirection = moveDirection - Vector3.new(0, 1, 0)
                end
                
                if moveDirection.Magnitude > 0 then
                    moveDirection = moveDirection.Unit * self.FlySpeed
                end
                
                if self.FlyBodyVelocity then
                    self.FlyBodyVelocity.Velocity = moveDirection
                end
                if self.FlyBodyGyro then
                    self.FlyBodyGyro.CFrame = currentCamera.CFrame
                end
                
                task.wait(0.01)
            end
        end)
    else
        if self.FlyBodyGyro then
            self.FlyBodyGyro:Destroy()
            self.FlyBodyGyro = nil
        end
        if self.FlyBodyVelocity then
            self.FlyBodyVelocity:Destroy()
            self.FlyBodyVelocity = nil
        end
    end
end

function MultiGrinder:getHumanoidRootPart()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

function MultiGrinder:getTargetNames(mode)
    local targetString
    if mode == "Combat" then
        targetString = self.CombatTargetNames
    elseif mode == "Mining" then
        targetString = self.MiningTargetNames
    elseif mode == "Event" then
        targetString = self.EventTargetNames
    end
    
    local names = {}
    if not targetString then return names end
    for name in string.gmatch(targetString, "[^,]+") do
        names[#names + 1] = name:gsub("^%s*(.-)%s*$", "%1")
    end
    return names
end

function MultiGrinder:findClosestTarget(position, names)
    local currentTime = tick()
    if currentTime - self.LastSearchTime < self.SearchCooldown and self.TargetCache.LastPosition then
        local dist = (position - self.TargetCache.LastPosition).Magnitude
        if dist < 5 then
            return self.TargetCache.Target, self.TargetCache.Key
        end
    end
    
    local closestTargetPart = nil 
    local closestTargetKey = nil 
    local minDistance = math.huge
    
    local descendants = Workspace:GetDescendants()
    for _, obj in ipairs(descendants) do
        for _, name in ipairs(names) do
            if string.find(string.lower(obj.Name), string.lower(name)) then
                local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChild("HumanoidRootPart")
                if targetPart and targetPart.Parent ~= LocalPlayer.Character then
                    local parent = targetPart.Parent
                    local humanoid = parent:FindFirstChildOfClass("Humanoid")
                    
                    if humanoid and humanoid.Health <= 0 then
                        continue
                    end
                    
                    local targetKey = humanoid and parent or targetPart
                    
                    if not self.IgnoredTargets[targetKey] then
                        local dist = (targetPart.Position - position).Magnitude
                        if dist < minDistance then
                            minDistance = dist
                            closestTargetPart = targetPart 
                            closestTargetKey = targetKey 
                        end
                    end
                end
            end
        end
    end
    
    self.LastSearchTime = currentTime
    self.TargetCache = {
        Target = closestTargetPart,
        Key = closestTargetKey,
        LastPosition = position
    }
    
    return closestTargetPart, closestTargetKey
end

-- NEW: Find closest target within a radius (for events)
function MultiGrinder:findClosestTargetInArea(position, radius, names)
    local closestTargetPart = nil 
    local closestTargetKey = nil 
    local minDistance = math.huge
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        for _, name in ipairs(names) do
            if string.find(string.lower(obj.Name), string.lower(name)) then
                local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChild("HumanoidRootPart")
                if targetPart and targetPart.Parent ~= LocalPlayer.Character then
                    local parent = targetPart.Parent
                    local humanoid = parent:FindFirstChildOfClass("Humanoid")
                    
                    if humanoid and humanoid.Health <= 0 then
                        continue
                    end
                    
                    local targetKey = humanoid and parent or targetPart
                    
                    if not self.IgnoredTargets[targetKey] then
                        local dist = (targetPart.Position - position).Magnitude
                        if dist <= radius and dist < minDistance then
                            minDistance = dist
                            closestTargetPart = targetPart 
                            closestTargetKey = targetKey 
                        end
                    end
                end
            end
        end
    end
    
    return closestTargetPart, closestTargetKey
end

function MultiGrinder:findClosestMobInArea(position, radius)
    local closestTargetPart = nil
    local closestTargetKey = nil
    local minDistance = math.huge

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 then
            local parentModel = obj.Parent
            if parentModel and parentModel ~= LocalPlayer.Character then
                local hrp = parentModel:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if not self.IgnoredTargets[parentModel] then
                        local dist = (hrp.Position - position).Magnitude
                        if dist <= radius and dist < minDistance then
                            minDistance = dist
                            closestTargetPart = hrp
                            closestTargetKey = parentModel
                        end
                    end
                end
            end
        end
    end
    
    return closestTargetPart, closestTargetKey
end

function MultiGrinder:findClosestResourceInArea(position, radius, names)
    local closestTargetPart = nil
    local closestTargetKey = nil
    local minDistance = math.huge

    for _, obj in ipairs(Workspace:GetDescendants()) do
        for _, name in ipairs(names) do
            if string.lower(obj.Name) == string.lower(name) then 
                local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChild("HumanoidRootPart")
                if targetPart and targetPart.Parent ~= LocalPlayer.Character then
                    local parentModel = targetPart.Parent
                    if not parentModel:FindFirstChildOfClass("Humanoid") then
                        if not self.IgnoredTargets[targetPart] then
                            local dist = (targetPart.Position - position).Magnitude
                            if dist <= radius and dist < minDistance then
                                minDistance = dist
                                closestTargetPart = targetPart
                                closestTargetKey = targetPart
                            end
                        end
                    end
                end
            end
        end
    end
    
    return closestTargetPart, closestTargetKey
end

function MultiGrinder:simulateAction(toolInstance)
    if not self.Remotes.UseItem or not toolInstance then return end
    
    local currentTime = tick()
    if currentTime - self.LastAttackTime < self.AttackCooldown then
        return
    end
    self.LastAttackTime = currentTime
    
    local args = {
        [1] = toolInstance,
        [2] = false,
        [5] = 1.1039999771118163
    }
    
    pcall(function()
        self.Remotes.UseItem:FireServer(unpack(args))
    end)
end

function MultiGrinder:equipTool(toolName)
    if not self.Remotes.EquipItem then return false end
    
    local success = pcall(function()
        self.Remotes.EquipItem:InvokeServer(toolName)
    end)
    
    if success then
        self.EquippedToolName = toolName
        return true
    end
    return false
end

function MultiGrinder:holdKey(keyCode, duration)
    VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    task.wait(duration)
    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
end

local function restoreCamera(self)
    if self.OriginalCameraCFrame then 
        Camera.CFrame = self.OriginalCameraCFrame 
        self.OriginalCameraCFrame = nil 
    end
end

function MultiGrinder:calculateTeleportPosition(targetPosition, currentPosition, mode)
    local finalPos

    if not self.SafeDistanceEnabled then
        local offset = (mode == "Combat") and CONFIG.Combat.TeleportOffset or CONFIG.Mining.TeleportOffset
        finalPos = targetPosition + offset
    else
        if mode == "Combat" then
            local direction = (currentPosition - targetPosition)
            direction = Vector3.new(direction.X, 0, direction.Z)
            
            if direction.Magnitude < 0.1 then
                direction = Vector3.new(math.random(-100, 100), 0, math.random(-100, 100))
            end
            
            direction = direction.Unit
            local safePosition = targetPosition + (direction * self.CombatSafeDistance)
            safePosition = safePosition + Vector3.new(0, 5, 0)
            
            finalPos = safePosition
        else
            local baseDistance = self.MiningSafeDistance
            local baseHeight = 3
            
            if self.MiningHitboxMode then
                self.LastMiningAngle = self.LastMiningAngle + 45
                if self.LastMiningAngle >= 360 then self.LastMiningAngle = 0 end
                
                local rad = math.rad(self.LastMiningAngle)
                local offsetX = math.cos(rad) * baseDistance
                local offsetZ = math.sin(rad) * baseDistance
                
                finalPos = targetPosition + Vector3.new(offsetX, baseHeight, offsetZ)
            else
                local direction = (currentPosition - targetPosition)
                direction = Vector3.new(direction.X, 0, direction.Z)
                
                if direction.Magnitude < 0.1 then
                    direction = Vector3.new(0, 0, 1)
                else
                    direction = direction.Unit
                end
                
                finalPos = targetPosition + (direction * baseDistance) + Vector3.new(0, baseHeight, 0)
            end
        end
    end

    if self.HeightOffsetEnabled then
        local height = (mode == "Combat") and self.CombatHeightOffset or self.MiningHeightOffset
        finalPos = finalPos + Vector3.new(0, height, 0)
    end

    return finalPos
end

function MultiGrinder:executePriorityAreaCombat(hrp)
    local toolName = self.CombatToolName
    
    local currentAreaCFrame = self.PriorityAreas[self.CurrentPriorityAreaIndex]
    if not currentAreaCFrame then
        self.CurrentPriorityAreaIndex = 1
        currentAreaCFrame = self.PriorityAreas[self.CurrentPriorityAreaIndex]
    end

    self.LastKnownPosition = hrp.Position
    hrp.CFrame = currentAreaCFrame

    local target = self.PriorityAreaTarget
    local targetIsValid = target and target.Parent and target.Parent:FindFirstChildOfClass("Humanoid") and target.Parent:FindFirstChildOfClass("Humanoid").Health > 0
    
    if not targetIsValid then
        self.PriorityAreaTarget = nil
        self.CurrentTargetIdentifier = nil 
        
        local newTarget, newTargetKey = self:findClosestMobInArea(hrp.Position, self.CombatPriorityAreaScanRadius)
        
        if newTarget then
            self.PriorityAreaTarget = newTarget
            self.CurrentTargetIdentifier = newTargetKey 
            target = self.PriorityAreaTarget
            self.PriorityAreaScanTimer = 0 
            self.TargetAcquiredTime = tick()
            self:updateGUI()
        else
            self.PriorityAreaScanTimer = self.PriorityAreaScanTimer + CONFIG.FarmSpeed
            
            if self.PriorityAreaScanTimer >= self.CombatPriorityAreaScanTime then
                self.PriorityAreaScanTimer = 0
                self.CurrentPriorityAreaIndex = self.CurrentPriorityAreaIndex + 1
                if self.CurrentPriorityAreaIndex > #self.PriorityAreas then
                    self.CurrentPriorityAreaIndex = 1 
                end
                self:updateGUI()
            end
            
            restoreCamera(self)
            return false
        end
    end

    local targetPos = self:calculateTeleportPosition(target.Position, hrp.Position, "Combat")
    
    self.LastKnownPosition = hrp.Position 
    hrp.CFrame = CFrame.new(targetPos)
    
    local char = LocalPlayer.Character
    if not char then return false end
    
    local equippedTool = char:FindFirstChild(toolName)
    
    if not equippedTool then
        if self:equipTool(toolName) then
            equippedTool = char:WaitForChild(toolName, 1.0)
        end
    end
    
    if equippedTool and Camera and target and target.Position then 
        if not self.OriginalCameraCFrame then
            self.OriginalCameraCFrame = Camera.CFrame 
        end
        
        Camera.CFrame = CFrame.new(targetPos, target.Position)
        
        self:simulateAction(equippedTool)
    else
        restoreCamera(self) 
    end

    return true
end

function MultiGrinder:executeCombatAction(hrp)
    if self.PriorityAreaEnabled and #self.PriorityAreas > 0 then
        return self:executePriorityAreaCombat(hrp)
    end
    
    if self.PriorityAreaTarget or self.PriorityAreaScanTimer > 0 then
        self.PriorityAreaTarget = nil
        self.PriorityAreaScanTimer = 0
        self.CurrentPriorityAreaIndex = 1
    end

    local toolName = self.CombatToolName
    local target = self.CurrentTarget
    
    local needsNewTarget = not target or not target.Parent or not target.Parent:FindFirstChildOfClass("Humanoid") or target.Parent:FindFirstChildOfClass("Humanoid").Health <= 0
    
    if needsNewTarget then
        local targetNames = self:getTargetNames("Combat")
        local newTarget, newTargetKey = self:findClosestTarget(hrp.Position, targetNames)
        
        if not newTarget then 
            self.CurrentTarget = nil 
            self.CurrentTargetIdentifier = nil 
            self.TargetAcquiredTime = nil 
            restoreCamera(self) 
            self:updateGUI() 
            return false 
        end
        
        self.CurrentTarget = newTarget
        self.CurrentTargetIdentifier = newTargetKey 
        target = self.CurrentTarget
        self.TargetAcquiredTime = tick()
        self:updateGUI() 
    end
    
    if self.AutoIgnoreEnabled and self.TargetAcquiredTime and (tick() - self.TargetAcquiredTime > 10) then
        local humanoid = target.Parent:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.Health > 0 and humanoid.Health == humanoid.MaxHealth then
            if self.CurrentTargetIdentifier then
                self.IgnoredTargets[self.CurrentTargetIdentifier] = true 
                print("[Multi-Bot] Auto-ignored stuck mob:", self.CurrentTargetIdentifier.Name)
            end
            
            self.CurrentTarget = nil 
            self.CurrentTargetIdentifier = nil 
            self.TargetAcquiredTime = nil
            restoreCamera(self)
            self:updateGUI()
            return false 
        end
        self.TargetAcquiredTime = tick() - 5
    end
    
    local char = LocalPlayer.Character
    if not char then return false end
    
    local equippedTool = char:FindFirstChild(toolName)
    
    if not equippedTool then
        if self:equipTool(toolName) then
            equippedTool = char:WaitForChild(toolName, 1.0)
        end
    end
    
    if not equippedTool then return false end
    
    local targetPos = self:calculateTeleportPosition(target.Position, hrp.Position, "Combat")
    
    self.LastKnownPosition = hrp.Position
    hrp.CFrame = CFrame.new(targetPos)
    
    if Camera and target and target.Position then 
        if not self.OriginalCameraCFrame then
            self.OriginalCameraCFrame = Camera.CFrame 
        end
        
        Camera.CFrame = CFrame.new(targetPos, target.Position)

        self:simulateAction(equippedTool)
    else
        restoreCamera(self) 
    end

    return true
end

