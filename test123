local function getRemotes()
    local remotes = {}
    local success, err = pcall(function()
        local clientRemotes = ReplicatedStorage:WaitForChild("ClientRemotes", 5)
        remotes.EquipItem = clientRemotes:WaitForChild("Inventory", 5):WaitForChild("EquipItem", 5)
        remotes.UseItem = clientRemotes:WaitForChild("Character", 5):WaitForChild("UseItem", 5)
    end)

    if not success then
        warn("[Fisher] Failed to get remotes: " .. tostring(err))
    end

    return remotes
end

