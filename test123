    MinBtn.MouseButton1Click:Connect(function()
        self.IsMinimized = not self.IsMinimized
        ContentContainer.Visible = not self.IsMinimized
        TabBar.Visible = not self.IsMinimized
        MainFrame:TweenSize(self.IsMinimized and UDim2.new(0, CONFIG.FrameWidth, 0, CONFIG.TitleBarHeight) or UDim2.new(0, CONFIG.FrameWidth, 0, self.InitialFrameHeight), "Out", "Quad", 0.2)
        MinBtn.Text = self.IsMinimized and "+" or "-"
    end)

    self.MainGui = {MainFrame = MainFrame}
end

-- [[ MAIN EXECUTION LOOP ]]
function MultiGrinder:start()
    self:setupGUI()
    
    -- Using Heartbeat for zero lag performance
    RunService.Heartbeat:Connect(function()
        local now = os.clock()
        if not self._lastUpdate then self._lastUpdate = 0 end
        
        if now - self._lastUpdate >= CONFIG.FarmSpeed then
            self._lastUpdate = now
            
            -- Independent Auto-Block
            if self.AutoBlockEnabled then
                self:handleBlock(true)
            end
            
            -- Farming Logic
            if self.Enabled then
                local hrp = self:getHumanoidRootPart()
                if hrp then
                    self.LastKnownPosition = hrp.Position
                    if self.Mode == "Combat" then 
                        self:executeCombatAction(hrp)
                    end
                end
            end
        end
    end)
end

