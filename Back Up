-- Format time
local function formatTime()
	local t = os.date("*t")
	return string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
end

-- Copy function
local function copyScript(text, button)
	if copyCooldown then return end
	copyCooldown = true
	
	-- Print to console for copying
	print("\n========== COPY THIS SCRIPT ==========\n")
	print(text)
	print("\n======================================\n")
	
	button.Text = "✅ Copied!"
	button.BackgroundColor3 = Config.UI.SuccessColor
	
	delay(2, function()
		if button and button.Parent then
			button.Text = "📋 Copy Script"
			button.BackgroundColor3 = Config.UI.AccentColor
		end
	end)
	
	delay(0.5, function()
		copyCooldown = false
	end)
end

-- Add action to UI
local function addAction(ui, actionType, data)
	local actionConfig = Config.Actions[actionType]
	if not actionConfig or not actionConfig.Enabled then return end
	
	-- Hide empty state
	ui.actionList.Visible = true
	ui.emptyLabel.Visible = false
	
	-- Create entry
	local entry = createTemplate()
	entry.LayoutOrder = -tick()
	entry.ColorBar.BackgroundColor3 = actionConfig.Color
	entry.Icon.Text = actionConfig.Icon
	entry.Title.Text = actionType
	entry.Title.TextColor3 = actionConfig.Color
	entry.Time.Text = formatTime()
	entry.Description.Text = data.Description or actionType .. " detected"
	entry.Position.Text = data.Position and string.format("%.1f, %.1f, %.1f", data.Position.X, data.Position.Y, data.Position.Z) or "N/A"
	
	-- Copy button
	local scriptCode = scriptTemplates[actionType] or "-- No template for " .. actionType
	entry.CopyBtn.MouseButton1Click:Connect(function()
		copyScript(scriptCode, entry.CopyBtn)
	end)
	
	entry.Parent = ui.actionList
	
	-- Animate in
	entry.BackgroundTransparency = 1
	entry.Size = UDim2.new(1, -10, 0, 0)
	TweenService:Create(entry, TweenInfo.new(0.3), {
		BackgroundTransparency = 0,
		Size = UDim2.new(1, -10, 0, 90)
	}):Play()
	
	-- Update count
	table.insert(actionHistory, 1, actionType)
	if #actionHistory > Config.MaxHistory then
		table.remove(actionHistory)
		-- Remove oldest UI entry
		for _, child in pairs(ui.actionList:GetChildren()) do
			if child:IsA("Frame") and child.Name ~= "UIListLayout" then
				TweenService:Create(child, TweenInfo.new(0.2), {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -10, 0, 0)
				}):Play()
				game:GetService("Debris"):AddItem(child, 0.2)
				break
			end
		end
	end
	
	ui.countLabel.Text = #actionHistory .. " action" .. (#actionHistory == 1 and "" or "s")
end

-- Setup detection
local function setupDetection(ui)
	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	local rootPart = character:WaitForChild("HumanoidRootPart")
	
	lastPosition = rootPart.Position
	lastTime = tick()
	
	-- Jump detection
	humanoid.Jumping:Connect(function(isActive)
		if isActive then
			addAction(ui, "Jump", {
				Description = "Player jumped!",
				Position = rootPart.Position
			})
		end
	end)
	
	-- Dash detection (speed check)
	RunService.Heartbeat:Connect(function()
		if not character or not rootPart then return end
		
		local now = tick()
		if now - lastTime >= 0.1 then
			local distance = (rootPart.Position - lastPosition).Magnitude
			local speed = distance / (now - lastTime)
			
			if speed > Config.DashThreshold and humanoid.MoveDirection.Magnitude > 0 then
				addAction(ui, "Dash", {
					Description = "Dashed at " .. math.floor(speed) .. " studs/s",
					Position = rootPart.Position
				})
			end
			
			lastPosition = rootPart.Position
			lastTime = now
		end
	end)
	
	-- Tool detection
	character.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then
			addAction(ui, "ToolEquip", {
				Description = "Equipped: " .. child.Name,
				Position = rootPart.Position
			})
		end
	end)
	
	character.ChildRemoved:Connect(function(child)
		if child:IsA("Tool") then
			addAction(ui, "ToolUnequip", {
				Description = "Unequipped: " .. child.Name,
				Position = rootPart.Position
			})
		end
	end)
	
	-- Damage detection
	humanoid.HealthChanged:Connect(function(newHealth)
		if newHealth < humanoid.Health then
			addAction(ui, "Damage", {
				Description = "Took " .. math.floor(humanoid.Health - newHealth) .. " damage",
				Position = rootPart.Position
			})
		end
	end)
	
	-- Death detection
	humanoid.Died:Connect(function()
		addAction(ui, "Death", {
			Description = "Player died",
			Position = rootPart.Position
		})
	end)
	
	-- Click detection
	local mouse = player:GetMouse()
	mouse.Button1Down:Connect(function()
		addAction(ui, "Click", {
			Description = "Left click at mouse position",
			Position = mouse.Hit.Position
		})
	end)
end

