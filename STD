end)

--// Notification
local function notify(text, color)
    local Notif = Instance.new("TextLabel")
    Notif.Size = UDim2.new(0, 200, 0, 30)
    Notif.Position = UDim2.new(0.5, -100, 0, -40)
    Notif.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    Notif.BorderSizePixel = 0
    Notif.Text = text
    Notif.TextColor3 = color or Color3.fromRGB(255, 255, 255)
    Notif.TextSize = 12
    Notif.Font = Enum.Font.Gotham
    Notif.Parent = ScreenGui
    
    local NC = Instance.new("UICorner")
    NC.CornerRadius = UDim.new(0, 6)
    NC.Parent = Notif
    
    TweenService:Create(Notif, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
        Position = UDim2.new(0.5, -100, 0, 10)
    }):Play()
    
    task.delay(2, function()
        TweenService:Create(Notif, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
            Position = UDim2.new(0.5, -100, 0, -40)
        }):Play()
        task.wait(0.5)
        Notif:Destroy()
    end)
end

notify("WaypointAuto Loaded!", Color3.fromRGB(100, 255, 100))

