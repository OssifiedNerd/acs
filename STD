                currentFarmMode = true
                DoRenderTeleport(renderFarm, teleportCFrameFarm)
                for i = FARM_DURATION, 1, -1 do CountdownLabel.Text = "Farm: " .. i .. "s"; task.wait(1) end
                currentFarmMode = false
                
                -- Back to original
                DoRenderTeleport(renderSpider, originalCF)
                CountdownLabel.Text = "Timer: 0s"
                spiderState = "🔴"
                SpiderStatusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
            end
        end
        SpiderStatusLabel.Text = "🕷️ " .. spiderState
    end
end)

