--// Bypass Methods

-- Method 1: Hook InvokeServer to bypass client-side wrappers
local TeleportRemote = ReplicatedStorage:WaitForChild("ClientRemotes"):WaitForChild("Map"):WaitForChild("TeleportToWaypoint")

local oldInvoke
if hookfunction then
    oldInvoke = hookfunction(TeleportRemote.InvokeServer, function(self, ...)
        if self == TeleportRemote then
            -- Call original directly, bypassing any middleware
            return oldInvoke(self, ...)
        end
        return oldInvoke(self, ...)
    end)
end

-- Method 2: Find and nuke cooldown values in common script locations
local function nukeCooldowns()
    local count = 0
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("ModuleScript") or obj:IsA("LocalScript") then
            -- Try to require and check for cooldown tables
            local success, result = pcall(function()
                local module = require(obj)
                if type(module) == "table" then
                    for k, v in pairs(module) do
                        if type(k) == "string" and k:lower():match("cooldown") or k:lower():match("debounce") or k:lower():match("spam") then
                            if type(v) == "number" then
                                module[k] = 0
                                count = count + 1
                            elseif type(v) == "boolean" then
                                module[k] = false
                                count = count + 1
                            end
                        end
                    end
                end
            end)
        end
        
        -- Check for NumberValue/IntValue named cooldown
        if obj:IsA("NumberValue") or obj:IsA("IntValue") then
            if obj.Name:lower():match("cooldown") or obj.Name:lower():match("delay") then
                obj.Value = 0
                count = count + 1
            end
        end
    end
    return count
end

-- Method 3: Hook FireServer/InvokeServer globally to bypass rate limiters
if hookfunction and getrawmetatable then
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)
    
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "InvokeServer" and self == TeleportRemote then
            -- Force through by calling raw
            return oldInvoke(self, ...)
        end
        return oldNamecall(self, ...)
    end)
    
    setreadonly(mt, true)
end

-- Method 4: Try to find the specific map teleport module and patch it
local function patchTeleportModule()
    -- Common paths where teleport logic might be
    local paths = {
        ReplicatedStorage:FindFirstChild("ClientModules"),
        ReplicatedStorage:FindFirstChild("Modules"),
        LocalPlayer:FindFirstChild("PlayerScripts"),
        game:GetService("StarterPlayer"):FindFirstChild("StarterPlayerScripts")
    }
    
    for _, path in pairs(paths) do
        if path then
            for _, module in pairs(path:GetDescendants()) do
                if module:IsA("ModuleScript") and (module.Name:lower():match("teleport") or module.Name:lower():match("map") or module.Name:lower():match("waypoint")) then
                    local success, req = pcall(require, module)
                    if success and type(req) == "table" then
                        -- Look for cooldown fields
                        for k, v in pairs(req) do
                            if type(k) == "string" and (k:lower():match("cooldown") or k:lower():match("lastteleport") or k:lower():match("nextteleport")) then
                                req[k] = type(v) == "number" and 0 or false
                            end
                        end
                    end
                end
            end
        end
    end
end

-- Run patches
local patched = nukeCooldowns()
