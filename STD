--// Teleport Function with Bypass
local function teleportTo(waypoint)
    local args = {waypoint}
    
    -- Anti-spam: slightly randomize if enabled (some games check for identical rapid calls)
    if Config.AntiSpamMode then
        args = {
            waypoint,
            [math.random(2, 50)] = tick() -- Random key with timestamp
        }
    end
    
    local success, err = pcall(function()
        -- Direct call bypassing any hooks/wrappers
        if getconnections then
            -- Disable connections on the remote temporarily
            local cons = getconnections(TeleportRemote.OnClientInvoke)
            for _, c in pairs(cons) do
                c:Disable()
            end
        end
        
        TeleportRemote:InvokeServer(unpack(args))
    end)
    
    if not success then
        StatusLabel.Text = "Err: " .. waypoint
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        warn("[WaypointAuto] Fail: " .. tostring(err))
    else
        StatusLabel.Text = "OK: " .. waypoint
        StatusLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
    end
    
    return success
end

--// Main Loop
local function runCycle()
    currentIndex = 1
    
    thread = task.spawn(function()
        while isRunning do
            local waypoint = Config.Waypoints[currentIndex]
            
            if waypoint then
                -- Run teleport in its own thread so cooldowns don't block
                task.spawn(function()
                    teleportTo(waypoint)
                end)
            end
            
            currentIndex = currentIndex + 1
            if currentIndex > #Config.Waypoints then
                if Config.AutoRestart then
                    currentIndex = 1
                else
                    isRunning = false
                    break
                end
            end
            
            task.wait(Config.Delay)
        end
        
        -- Reset UI when done
        if not Config.AutoRestart then
            ToggleButton.Text = "OFF"
            ToggleButton.TextColor3 = Color3.fromRGB(255, 70, 70)
            StatusLabel.Text = "Finished"
            StatusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        end
    end)
end

local function stopCycle()
    isRunning = false
end

