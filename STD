-- Helper function to create TP button with render button
local function CreateTPButton(name, color, savedCF, renderCF)
    local Row = Instance.new("Frame")
    Row.Size = UDim2.new(0.9, 0, 0, 30)
    Row.BackgroundTransparency = 1
    Row.Parent = ContentFrame
    local RowLayout = Instance.new("UIListLayout", Row)
    RowLayout.FillDirection = Enum.FillDirection.Horizontal
    RowLayout.Padding = UDim.new(0, 5)

    local MainBtn = Instance.new("TextButton")
    MainBtn.Size = UDim2.new(0.75, 0, 1, 0)
    MainBtn.Text = savedCF and (name .. " ✓") or name
    MainBtn.BackgroundColor3 = savedCF and Color3.fromRGB(0, 200, 0) or color
    MainBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    MainBtn.Font = Enum.Font.GothamBold
    MainBtn.TextSize = 13
    MainBtn.Parent = Row
    Instance.new("UICorner", MainBtn).CornerRadius = UDim.new(0, 6)

    local RenderBtn = Instance.new("TextButton")
    RenderBtn.Size = UDim2.new(0.25, 0, 1, 0)
    RenderBtn.Text = "R"
    RenderBtn.BackgroundColor3 = renderCF and Color3.fromRGB(0, 150, 200) or Color3.fromRGB(80, 80, 80)
    RenderBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    RenderBtn.Font = Enum.Font.GothamBold
    RenderBtn.TextSize = 12
    RenderBtn.Parent = Row
    Instance.new("UICorner", RenderBtn).CornerRadius = UDim.new(0, 6)

    return Row, MainBtn, RenderBtn
end

