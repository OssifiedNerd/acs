--// MOB CACHE - ULTRA OPTIMIZED
local MobCache = {
    allMobs = {},
    guardians = {},
    spiders = {},
    royalSpiders = {},
    lastUpdate = 0,
    updateInterval = 0.5,
}

local function HasValidRig(model)
    if not model then return false end
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local torso = model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso")
    if not torso then return false end
    return true, hrp
end

function MobCache.Update()
    local now = tick()
    if now - MobCache.lastUpdate < MobCache.updateInterval then return end
    MobCache.lastUpdate = now

    MobCache.allMobs = {}
    MobCache.guardians = {}
    MobCache.spiders = {}
    MobCache.royalSpiders = {}

    local entities = workspace:FindFirstChild("Entities")
    local scanTarget = entities and entities:GetChildren() or workspace:GetChildren()

    for _, obj in ipairs(scanTarget) do
        if obj:IsA("Model") then
            local name = obj.Name
            local blocked = false
            for _, ignore in ipairs(ignoreList) do
                if string.find(name, ignore, 1, true) then
                    blocked = true
                    break
                end
            end
            if not blocked and (targetMobs[name] or farmMobs[name]) then
                local valid, hrp = HasValidRig(obj)
                if valid then
                    table.insert(MobCache.allMobs, {model = obj, hrp = hrp, name = name})
                    if name == "crystalGuardianModel" then
                        table.insert(MobCache.guardians, {model = obj, hrp = hrp})
                    elseif name == "spiderModel" then
                        table.insert(MobCache.spiders, {model = obj, hrp = hrp})
                    elseif name == "royalSpiderModel" then
                        table.insert(MobCache.royalSpiders, {model = obj, hrp = hrp})
                    end
                end
            end
        end
    end
end

function MobCache.GetNearbyGuardians(root, radius)
    MobCache.Update()
    local count = 0
    for _, g in ipairs(MobCache.guardians) do
        if g.hrp and g.hrp.Parent and root then
            if (g.hrp.Position - root.Position).Magnitude <= radius then
                count += 1
                if count >= 5 then break end
            end
        end
    end
    return count
end

function MobCache.GetNearbySpiders(root, radius)
    MobCache.Update()
    if not root then return false end
    for _, s in ipairs(MobCache.spiders) do
        if s.hrp and s.hrp.Parent then
            if (s.hrp.Position - root.Position).Magnitude <= radius then
                return true
            end
        end
    end
    return false
end

function MobCache.GetAttackTargets(root, range, isFarmMode)
    MobCache.Update()
    local result = {}
    local royalTarget = nil

    for _, entry in ipairs(MobCache.allMobs) do
        local mob = entry.model
        local hrp = entry.hrp
        local name = entry.name

        if not hrp or not hrp.Parent then continue end

        local isTarget = false
        if isFarmMode then
            isTarget = farmMobs[name] == true
        else
            isTarget = targetMobs[name] ~= nil
        end

        if isTarget then
            local dist = (hrp.Position - root.Position).Magnitude
            if dist < range then
                if isFarmMode then
                    table.insert(result, {model = mob, dist = dist, hrp = hrp})
                else
                    table.insert(result, {model = mob, priority = targetMobs[name], dist = dist, hrp = hrp})
                    if name == "royalSpiderModel" and not royalTarget then
                        royalTarget = {model = mob, hrp = hrp}
                    end
                end
            end
        end
    end

    return result, royalTarget
end

function MobCache.GetRoyalSpiderInRange(root, range)
    MobCache.Update()
    for _, entry in ipairs(MobCache.royalSpiders) do
        if entry.hrp and entry.hrp.Parent and root then
            if (entry.hrp.Position - root.Position).Magnitude < range then
                return entry.model, entry.hrp
            end
        end
    end
    return nil, nil
end

