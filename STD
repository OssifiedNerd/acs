--// Remote Reference
local TeleportRemote = ReplicatedStorage:WaitForChild("ClientRemotes"):WaitForChild("Map"):WaitForChild("TeleportToWaypoint")

--// Functions
local function updateButton(state)
    isRunning = state
    if state then
        ToggleButton.Text = "ON"
        ToggleButton.TextColor3 = Color3.fromRGB(80, 255, 80)
        StatusLabel.Text = "Running..."
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        -- Button flash effect
        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(40, 100, 40)
        }):Play()
    else
        ToggleButton.Text = "OFF"
        ToggleButton.TextColor3 = Color3.fromRGB(255, 80, 80)
        StatusLabel.Text = "Stopped"
        StatusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        
        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        }):Play()
    end
end

local function teleportTo(waypoint)
    local success, err = pcall(function()
        TeleportRemote:InvokeServer(waypoint)
    end)
    
    if not success then
        warn("[WaypointAuto] Failed to teleport to '" .. waypoint .. "': " .. tostring(err))
        StatusLabel.Text = "Error: " .. waypoint
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    else
        StatusLabel.Text = "At: " .. waypoint
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    end
    
    return success
end

local function runCycle()
    if connection then
        connection:Disconnect()
        connection = nil
    end
    
    currentIndex = 1
    
    connection = task.spawn(function()
        while isRunning do
            local waypoint = Config.Waypoints[currentIndex]
            
            if waypoint then
                teleportTo(waypoint)
            end
            
            currentIndex = currentIndex + 1
            
            if currentIndex > #Config.Waypoints then
                if Config.AutoRestart then
                    currentIndex = 1
                else
                    updateButton(false)
                    break
                end
            end
            
            -- Delay between teleports (in seconds)
            -- task.wait accepts seconds, so 0.01 = 10ms
            task.wait(Config.Delay)
        end
    end)
end

local function stopCycle()
    isRunning = false
    if connection then
        -- Cannot disconnect a thread, just let the loop die
        connection = nil
    end
end

--// Button Handler
ToggleButton.MouseButton1Click:Connect(function()
    if isRunning then
        stopCycle()
        updateButton(false)
    else
        updateButton(true)
        runCycle()
    end
end)

