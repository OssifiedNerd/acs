--// Main Attack Loop (targeted attacks at attackSpeed interval)
task.spawn(function()
    while true do
        local success = pcall(function()
            local hrp = getHumanoidRootPart()
            if hrp then
                -- Auto-Teleport (uses SAFE_FARM_DURATION)
                if not safeFarmMode and not currentFarmMode then
                    local crystalCount = MobCache.GetNearbyGuardians(hrp, nearbyRadius)
                    if crystalCount >= 5 and autoTeleportEnabled and not isTeleporting and teleportCFrameFarm then
                        isTeleporting = true; safeFarmMode = true
                        local originalGuardianCF = hrp.CFrame
                        DoRenderTeleport(renderFarm, teleportCFrameFarm)
                        for i = SAFE_FARM_DURATION, 1, -1 do
                            CountdownLabel.Text = "Safe Farm: " .. i .. "s"
                            task.wait(1)
                        end
                        CountdownLabel.Text = "Timer: 0s"
                        DoRenderTeleport(renderSpider, originalGuardianCF)
                        safeFarmMode = false; isTeleporting = false
                    end
                end

                -- Targeted Wand Attack
                if wandEnabled then
                    local mobs, royalTarget = MobCache.GetAttackTargets(hrp, attackRange, currentFarmMode)
                    local isFarm = currentFarmMode

                    if hoverEnabled and lockedRoyalSpider and lockedRoyalSpider:FindFirstChild("HumanoidRootPart") then
                        local dist = (lockedRoyalSpider.HumanoidRootPart.Position - hrp.Position).Magnitude
                        if dist < attackRange then
                            royalTarget = {model = lockedRoyalSpider, hrp = lockedRoyalSpider.HumanoidRootPart}
                        end
                    end

                    local targetsToAttack = {}
                    if royalTarget then
                        targetsToAttack = {royalTarget}
                    else
                        if isFarm then
                            table.sort(mobs, function(a, b) return a.dist < b.dist end)
                        else
                            table.sort(mobs, function(a, b)
                                if a.priority == b.priority then return a.dist < b.dist else return a.priority < b.priority end
                            end)
                        end
                        targetsToAttack = mobs
                    end

                    if #targetsToAttack > 0 then
                        local topMob = targetsToAttack[1].model
                        StatusLabel.Text = "Target: " .. topMob.Name .. (currentFarmMode and " [FARM]" or (safeFarmMode and " [SAFE]" or ""))
                        StatusLabel.TextColor3 = mobColors[topMob.Name] or Color3.fromRGB(255, 255, 255)
                        for _, mob in ipairs(targetsToAttack) do
                            if mob.hrp and mob.hrp.Parent then
                                for i = 1, multiAttacks do
                                    pcall(function()
                                        Event:FireServer("use", "wand", "place", mob.hrp.Position)
                                    end)
                                    if i < multiAttacks then task.wait(0.03) end
                                end
                            end
                        end
                    else
                        StatusLabel.Text = "Target: None"
                        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
                    end
                else
                    StatusLabel.Text = "Target: None"
                    StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
                end
            end
        end)
        task.wait(attackSpeed)
    end
end)

