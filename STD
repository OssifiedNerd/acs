--// Settings Manager
local SettingsManager = {}

function SettingsManager.SerializeCFrame(cf)
    if not cf then return nil end
    return {
        pos = {cf.Position.X, cf.Position.Y, cf.Position.Z},
        rot = {cf.LookVector.X, cf.LookVector.Y, cf.LookVector.Z}
    }
end

function SettingsManager.DeserializeCFrame(data)
    if not data or not data.pos then return nil end
    local pos = Vector3.new(unpack(data.pos))
    local look = Vector3.new(unpack(data.rot))
    return CFrame.new(pos, pos + look)
end

function SettingsManager.SerializeUDim2(udim2)
    if not udim2 then return nil end
    return {
        X = {udim2.X.Scale, udim2.X.Offset},
        Y = {udim2.Y.Scale, udim2.Y.Offset}
    }
end

function SettingsManager.DeserializeUDim2(data)
    if not data then return nil end
    return UDim2.new(data.X[1], data.X[2], data.Y[1], data.Y[2])
end

function SettingsManager.Load()
    local success, result = pcall(function()
        if not isfile(SETTINGS_FILE) then return nil end
        return HttpService:JSONDecode(readfile(SETTINGS_FILE))
    end)

    if success and result then
        for key, default in pairs(Settings) do
            if result[key] ~= nil then
                if key:find("CFrame") or key:find("render") then
                    Settings[key] = SettingsManager.DeserializeCFrame(result[key])
                elseif key == "guiPosition" then
                    Settings[key] = SettingsManager.DeserializeUDim2(result[key])
                else
                    Settings[key] = result[key]
                end
            end
        end
        return true
    end
    return false
end

function SettingsManager.Save()
    local now = tick()
    if now - lastSaveTime < SAVE_COOLDOWN then return end
    lastSaveTime = now

    local dataToSave = {}
    for key, value in pairs(Settings) do
        if key:find("CFrame") or key:find("render") then
            dataToSave[key] = SettingsManager.SerializeCFrame(value)
        elseif key == "guiPosition" then
            dataToSave[key] = SettingsManager.SerializeUDim2(value)
        else
            dataToSave[key] = value
        end
    end

    pcall(function()
        writefile(SETTINGS_FILE, HttpService:JSONEncode(dataToSave))
    end)
end

local autoSaveConnection
function SettingsManager.AutoSave()
    if autoSaveConnection then autoSaveConnection:Disconnect() end
    autoSaveConnection = task.delay(SAVE_COOLDOWN, SettingsManager.Save)
end

SettingsManager.Load()

