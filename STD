    task.wait(1)
    local hum = char:WaitForChild("Humanoid")
    if hum and not frozen then
        hum.WalkSpeed = walkSpeed
    end
    -- Re-apply fly if active after respawn
    if flyEnabled then
        task.delay(0.5, SetupFly)
    end
    -- Clean up hover constraints on respawn
    if hoverBP then hoverBP = nil end
    if hoverBG then hoverBG = nil end
end)
