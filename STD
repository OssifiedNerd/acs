            originalCF = hrp.CFrame
            if teleportCFrameDesert and teleportCFrameTundra and teleportCFrameForest1 
               and teleportCFrameForest2 and teleportCFrameForest3 and teleportCFrameForest4 
               and teleportCFrameFarm and teleportCFrameSpider then
