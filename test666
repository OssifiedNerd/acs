--[[
    MM2 Coin Collector - Rewritten (Stable Build)
    Fixes: Deprecated movers, race conditions, memory leaks, 
           unreliable bag checks, and jittery movement.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

-- Configuration
local CONFIG = {
    CoinName = "Coin_Server",        -- Adjust if MM2 uses different name
    FlySpeed = 35,                   -- Studs per second
    CollectionRadius = 2.5,          -- Distance to register pickup
    MaxBag = 40,                     -- 50 if you own Elite Gamepass [^1^]
    SafeMode = true,
    SafeDistance = 50,               -- Distance from murderer to pause
    Noclip = true,
    Transparency = 0.3,              -- Ghost effect
    ScanInterval = 0.3,              -- How often to refresh coin list
    StuckTimeout = 4,                -- Seconds before blacklisting a coin
    EnableDebugUI = true,
}

-- State Machine
local State = {
    Idle = 0,
    Moving = 1,
    Collecting = 2,
    Evading = 3,
    Resetting = 4,
}

-- Runtime Variables
local currentState = State.Idle
local activeConnections = {}
local coinQueue = {}
local blacklist = {}
local currentTarget = nil
local lastTargetPos = nil
local stuckTimer = 0
local coinCount = 0
local isRunning = false
local character, rootPart, humanoid = nil, nil, nil

-- Utility: Clean up connections
local function cleanup()
    for _, conn in ipairs(activeConnections) do
        if conn then pcall(function() conn:Disconnect() end) end
    end
    activeConnections = {}
    currentState = State.Idle
    currentTarget = nil
end

-- Utility: Safe character wait
local function refreshCharacter()
    character = player.Character
    if not character then return false end
    rootPart = character:FindFirstChild("HumanoidRootPart")
    humanoid = character:FindFirstChild("Humanoid")
    return rootPart ~= nil and humanoid ~= nil
end

-- Utility: Check if actually in round
local function isInRound()
    -- Method 1: PlayerData Role check
    local pData = player:FindFirstChild("PlayerData")
    if pData then
        local role = pData:FindFirstChild("Role")
        if role and role:IsA("ValueBase") then
            local val = role.Value
            if val and val ~= "" and val ~= "None" then
                return true
            end
        end
    end
    -- Method 2: Y-position sanity check (lobby is usually high up)
    if rootPart and rootPart.Position.Y > -100 then
        return true
    end
    return false
end

-- Utility: Get murderer HRP
local function getMurdererHRP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        local pData = plr:FindFirstChild("PlayerData")
        if pData then
            local role = pData:FindFirstChild("Role")
            if role and role:IsA("ValueBase") and role.Value == "Murderer" then
                local char = plr.Character
                if char then
                    return char:FindFirstChild("HumanoidRootPart")
                end
            end
        end
    end
    return nil
end

-- IMPROVED BAG CHECK: Multi-layered with event listening
local function setupBagTracking()
    -- Try to find the actual value object and listen to changes
    local container = player:FindFirstChild("CoinContainer")
    if container then
        local val = container:FindFirstChild("CoinValue") or container:FindFirstChild("Coins")
        if val and val:IsA("ValueBase") then
            coinCount = val.Value
            local conn = val:GetPropertyChangedSignal("Value"):Connect(function()
                coinCount = val.Value
            end)
            table.insert(activeConnections, conn)
            return
        end
    end
    
    -- Fallback: Listen to UI changes if value object not found
    local function tryUI()
        local mainGui = player:WaitForChild("PlayerGui", 3)
        if not mainGui then return end
        local gameUI = mainGui:FindFirstChild("MainGui")
        if not gameUI then return end
        local coinBag = gameUI:FindFirstChild("CoinBag")
        if not coinBag then return end
        local label = coinBag:FindFirstChild("TextLabel")
        if not label then return end
        
        local function parse()
            local text = label.Text
            local num = text:match("(%d+)%s*/")
            if num then
                coinCount = tonumber(num) or coinCount
            end
        end
        
        parse()
        local conn = label:GetPropertyChangedSignal("Text"):Connect(parse)
        table.insert(activeConnections, conn)
    end
    
    pcall(tryUI)
end

-- Noclip: Efficient single-connection method
local function enableNoclip()
    if not CONFIG.Noclip then return end
    local conn = RunService.Stepped:Connect(function()
        if not character then return end
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
                if CONFIG.Transparency > 0 and part.Name ~= "HumanoidRootPart" then
                    part.LocalTransparencyModifier = CONFIG.Transparency
                end
            end
        end
    end)
    table.insert(activeConnections, conn)
end

-- COIN SCANNER: Efficient workspace polling
local function scanCoins()
    local coins = {}
    local searchRoot = Workspace:FindFirstChild("Normal")
    if searchRoot then
        local cc = searchRoot:FindFirstChild("CoinContainer")
        if cc then searchRoot = cc end
    else
        searchRoot = Workspace
    end

    local myPos = rootPart and rootPart.Position or Vector3.zero
    
    for _, obj in ipairs(searchRoot:GetDescendants()) do
        if obj.Name == CONFIG.CoinName and obj:IsA("BasePart") then
            if not blacklist[obj] and obj.Parent ~= nil then
                table.insert(coins, {
                    Object = obj,
                    Distance = (myPos - obj.Position).Magnitude
                })
            end
        end
    end

    table.sort(coins, function(a, b)
        return a.Distance < b.Distance
    end)
    
    -- Rebuild queue
    coinQueue = {}
    for _, data in ipairs(coins) do
        table.insert(coinQueue, data.Object)
    end
end

-- MOVEMENT ENGINE: Smooth CFrame interpolation (no deprecated movers)
local function moveToTarget(targetPos, dt)
    if not rootPart then return false end
    
    local myPos = rootPart.Position
    local direction = (targetPos - myPos)
    local distance = direction.Magnitude
    
    if distance <= CONFIG.CollectionRadius then
        return true -- Reached target
    end
    
    direction = direction.Unit
    local moveStep = direction * CONFIG.FlySpeed * dt
    
    -- Clamp step so we don't overshoot
    if moveStep.Magnitude > distance then
        moveStep = direction * distance
    end
    
    local newPos = myPos + moveStep
    local lookCFrame = CFrame.new(newPos, targetPos)
    
    -- Smooth orientation, instant position for responsiveness
    rootPart.CFrame = lookCFrame
    rootPart.AssemblyLinearVelocity = Vector3.zero -- Cancel gravity/momentum
    rootPart.AssemblyAngularVelocity = Vector3.zero
    
    return false
end

-- SAFE RESET: Single-shot void teleport instead of 5-second spam
local function resetCharacter()
    currentState = State.Resetting
    cleanup()
    
    task.spawn(function()
        -- Attempt clean death
        for _ = 1, 3 do
            if rootPart then
                pcall(function()
                    rootPart.CFrame = CFrame.new(0, -500, 0)
                    rootPart.AssemblyLinearVelocity = Vector3.new(0, -200, 0)
                end)
            end
            if humanoid then
                pcall(function() humanoid.Health = 0 end)
            end
            task.wait(0.2)
        end
    end)
end

-- MAIN LOOP: State machine
local function mainLoop()
    local lastScan = 0
    
    while isRunning do
        local dt = RunService.Heartbeat:Wait()
        
        -- Validate character
        if not refreshCharacter() or humanoid.Health <= 0 then
            currentState = State.Idle
            task.wait(0.5)
            continue
        end
        
        -- Validate round state
        if not isInRound() then
            currentState = State.Idle
            task.wait(1)
            continue
        end
        
        -- Check bag full
        if coinCount >= CONFIG.MaxBag then
            resetCharacter()
            break
        end
        
        -- Safe mode: Murderer proximity check
        if CONFIG.SafeMode then
            local murdererHRP = getMurdererHRP()
            if murdererHRP then
                local dist = (rootPart.Position - murdererHRP.Position).Magnitude
                if dist < CONFIG.SafeDistance then
                    currentState = State.Evading
                    -- Move away from murderer
                    local awayDir = (rootPart.Position - murdererHRP.Position).Unit
                    local safePos = rootPart.Position + awayDir * 20
                    moveToTarget(safePos + Vector3.new(0, 10, 0), dt)
                    continue
                end
            end
        end
        
        -- Periodic coin scan
        if tick() - lastScan > CONFIG.ScanInterval then
            scanCoins()
            lastScan = tick()
        end
        
        -- Target acquisition
        if not currentTarget or not currentTarget.Parent or blacklist[currentTarget] then
            currentTarget = coinQueue[1]
            stuckTimer = tick()
            lastTargetPos = currentTarget and currentTarget.Position or nil
        end
        
        if not currentTarget then
            currentState = State.Idle
            continue
        end
        
        currentState = State.Moving
        
        -- Stuck detection: if target hasn't moved and we're not reaching it
        if lastTargetPos and (lastTargetPos - currentTarget.Position).Magnitude < 0.1 then
            if tick() - stuckTimer > CONFIG.StuckTimeout then
                blacklist[currentTarget] = true
                task.delay(15, function() blacklist[currentTarget] = nil end)
                currentTarget = nil
                continue
            end
        else
            lastTargetPos = currentTarget.Position
            stuckTimer = tick()
        end
        
        -- Move to coin
        local reached = moveToTarget(currentTarget.Position, dt)
        
        if reached then
            currentState = State.Collecting
            
            -- Force touch (server-side usually handles pickup via touched event)
            pcall(function()
                rootPart.CFrame = CFrame.new(currentTarget.Position)
                firetouchinterest(rootPart, currentTarget, 0)
                task.wait()
                firetouchinterest(rootPart, currentTarget, 1)
            end)
            
            -- Immediately check if bag filled from this coin
            task.wait(0.1)
            if coinCount >= CONFIG.MaxBag then
                resetCharacter()
                break
            end
            
            -- Blacklist briefly to prevent re-targeting same coin
            blacklist[currentTarget] = true
            task.delay(8, function() blacklist[currentTarget] = nil end)
            
            table.remove(coinQueue, 1)
            currentTarget = nil
        end
    end
end

-- DEBUG UI (Optional)
local function createUI()
    if not CONFIG.EnableDebugUI then return end
    
    local sg = Instance.new("ScreenGui")
    sg.Name = "MM2CollectorDebug"
    sg.ResetOnSpawn = false
    sg.Parent = player:WaitForChild("PlayerGui")
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 220, 0, 100)
    frame.Position = UDim2.new(0, 10, 0, 10)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BorderSizePixel = 0
    frame.Parent = sg
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = frame
    
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(1, -10, 0, 25)
    status.Position = UDim2.new(0, 5, 0, 5)
    status.Text = "Status: Initializing..."
    status.TextColor3 = Color3.fromRGB(255, 255, 255)
    status.BackgroundTransparency = 1
    status.Font = Enum.Font.GothamBold
    status.TextSize = 14
    status.Parent = frame
    
    local coins = Instance.new("TextLabel")
    coins.Size = UDim2.new(1, -10, 0, 25)
    coins.Position = UDim2.new(0, 5, 0, 35)
    coins.Text = "Coins: 0 / " .. CONFIG.MaxBag
    coins.TextColor3 = Color3.fromRGB(0, 255, 128)
    coins.BackgroundTransparency = 1
    coins.Font = Enum.Font.Gotham
    coins.TextSize = 14
    coins.Parent = frame
    
    local target = Instance.new("TextLabel")
    target.Size = UDim2.new(1, -10, 0, 25)
    target.Position = UDim2.new(0, 5, 0, 65)
    target.Text = "Target: None"
    target.TextColor3 = Color3.fromRGB(200, 200, 200)
    target.BackgroundTransparency = 1
    target.Font = Enum.Font.Gotham
    target.TextSize = 12
    target.Parent = frame
    
    -- Update loop
    task.spawn(function()
        while sg.Parent do
            task.wait(0.2)
            local stateNames = {"Idle", "Moving", "Collecting", "Evading", "Resetting"}
            status.Text = "Status: " .. (stateNames[currentState + 1] or "Unknown")
            coins.Text = string.format("Coins: %d / %d", coinCount, CONFIG.MaxBag)
            
            if currentTarget then
                target.Text = "Target: " .. currentTarget.Name .. " (" .. math.floor((rootPart.Position - currentTarget.Position).Magnitude) .. " studs)"
            else
                target.Text = "Target: None"
            end
        end
    end)
    
    table.insert(activeConnections, {
        Disconnect = function() sg:Destroy() end
    })
end

-- INITIALIZATION
local function start()
    cleanup()
    if not refreshCharacter() then
        warn("[MM2 Collector] Character not available")
        return
    end
    
    isRunning = true
    currentState = State.Idle
    coinCount = 0
    blacklist = {}
    coinQueue = {}
    
    setupBagTracking()
    enableNoclip()
    createUI()
    
    task.spawn(mainLoop)
end

-- Respawn handler
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    -- Wait for character to fully load
    task.delay(3, function()
        if isInRound() then
            start()
        end
    end)
end)

-- Death handler to stop loops cleanly
player.CharacterRemoving:Connect(function()
    isRunning = false
    cleanup()
end)

-- Auto-start if already in game
if player.Character and isInRound() then
    task.delay(2, start)
end
