--[[
    MM2 Coin Collector - Auto-Max Bag Edition
    Fixes: Auto-start failure, hardcoded bag limit, silent errors.
    Press RIGHT SHIFT to force start/stop at any time.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()

-- CONFIGURATION
local CONFIG = {
    CoinName = "Coin_Server",        -- Change this if your executor/inspect shows a different name
    FlySpeed = 30,
    CollectionRadius = 3,
    SafeMode = true,
    SafeDistance = 45,
    NoclipTransparency = 0.4,
    ScanInterval = 0.4,
    StuckTimeout = 3.5,
    DebugPrints = true,              -- Set to false to hide console spam
}

-- STATE
local isRunning = false
local connections = {}
local coinQueue = {}
local blacklist = {}
local currentTarget = nil
local stuckTick = 0
local lastPos = nil
local maxBag = 40                   -- Will auto-update from UI
local currentCoins = 0

-- UTILITIES
local function log(...)
    if CONFIG.DebugPrints then
        print("[MM2 Collector]", ...)
    end
end

local function cleanup()
    isRunning = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    currentTarget = nil
    coinQueue = {}
    log("Cleaned up all connections.")
end

local function getCharacterParts()
    local char = player.Character
    if not char then return nil, nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if hrp and hum then
        return char, hrp, hum
    end
    return nil, nil, nil
end

-- AUTO DETECT BAG SIZE: Reads "24 / 40" or "24/50" from the UI
local function updateBagInfo()
    pcall(function()
        local pg = player:FindFirstChild("PlayerGui")
        if not pg then return end
        local mainGui = pg:FindFirstChild("MainGui")
        if not mainGui then return end
        local gameUI = mainGui:FindFirstChild("Game")
        if not gameUI then return end
        local coinBag = gameUI:FindFirstChild("CoinBag")
        if not coinBag then return end
        local label = coinBag:FindFirstChild("TextLabel")
        if not label then return end

        local text = label.Text
        -- Matches: "24 / 40", "24/40", "24 /40", etc.
        local current, maximum = text:match("(%d+)%s*/%s*(%d+)")
        if current and maximum then
            currentCoins = tonumber(current)
            local newMax = tonumber(maximum)
            if newMax and newMax ~= maxBag then
                maxBag = newMax
                log("Auto-detected bag capacity:", maxBag)
            end
        end
    end)
end

-- MURDERER DETECTION
local function getMurdererHRP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        local pData = plr:FindFirstChild("PlayerData")
        if pData then
            local role = pData:FindFirstChild("Role")
            if role and role:IsA("ValueBase") and role.Value == "Murderer" then
                local char = plr.Character
                if char then
                    return char:FindFirstChild("HumanoidRootPart")
                end
            end
        end
    end
    return nil
end

-- NOCLIP
local function enableNoclip()
    local conn = RunService.Stepped:Connect(function()
        local char = player.Character
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
                if part.Name ~= "HumanoidRootPart" then
                    part.LocalTransparencyModifier = CONFIG.NoclipTransparency
                end
            end
        end
    end)
    table.insert(connections, conn)
    log("Noclip enabled.")
end

-- COIN SCANNER: Searches everywhere
local function scanCoins()
    local char, hrp = getCharacterParts()
    if not hrp then return end

    local found = {}
    local myPos = hrp.Position

    -- Try specific path first
    local searchRoot = Workspace:FindFirstChild("Normal")
    if searchRoot then
        local cc = searchRoot:FindFirstChild("CoinContainer")
        if cc then searchRoot = cc end
    else
        searchRoot = Workspace
    end

    for _, obj in ipairs(searchRoot:GetDescendants()) do
        if obj.Name == CONFIG.CoinName and obj:IsA("BasePart") and obj.Parent then
            if not blacklist[obj] then
                table.insert(found, {
                    Obj = obj,
                    Dist = (myPos - obj.Position).Magnitude
                })
            end
        end
    end

    table.sort(found, function(a, b) return a.Dist < b.Dist end)

    coinQueue = {}
    for _, data in ipairs(found) do
        table.insert(coinQueue, data.Obj)
    end
end

-- MOVEMENT: Direct CFrame stepping
local function flyTo(targetPos, dt)
    local char, hrp, hum = getCharacterParts()
    if not hrp then return false end

    local myPos = hrp.Position
    local dir = targetPos - myPos
    local dist = dir.Magnitude

    if dist <= CONFIG.CollectionRadius then
        return true
    end

    dir = dir.Unit
    local step = dir * CONFIG.FlySpeed * dt
    if step.Magnitude > dist then step = dir * dist end

    local newPos = myPos + step
    hrp.CFrame = CFrame.new(newPos, targetPos)
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    return false
end

-- RESET CHARACTER (clean death)
local function resetCharacter()
    log("Bag full or manual reset! Dropping coins...")
    isRunning = false
    cleanup()

    task.spawn(function()
        for _ = 1, 5 do
            local _, hrp, hum = getCharacterParts()
            if hrp then
                pcall(function()
                    hrp.CFrame = CFrame.new(hrp.Position.X, -500, hrp.Position.Z)
                    hrp.AssemblyLinearVelocity = Vector3.new(0, -300, 0)
                end)
            end
            if hum then
                pcall(function() hum.Health = 0 end)
            end
            task.wait(0.15)
        end
    end)
end

-- MAIN COLLECTOR LOOP
local function collectorLoop()
    log("Collector loop started.")
    local lastScan = 0

    while isRunning do
        local dt = RunService.Heartbeat:Wait()

        local char, hrp, hum = getCharacterParts()
        if not char or not hrp or not hum or hum.Health <= 0 then
            log("Character died or missing. Stopping.")
            break
        end

        -- Update bag info every frame (cheap)
        updateBagInfo()

        -- Check if full (auto-detected max)
        if currentCoins >= maxBag then
            log("Bag is full! (" .. currentCoins .. "/" .. maxBag .. ")")
            resetCharacter()
            break
        end

        -- Safe mode evasion
        if CONFIG.SafeMode then
            local murderer = getMurdererHRP()
            if murderer then
                local dist = (hrp.Position - murderer.Position).Magnitude
                if dist < CONFIG.SafeDistance then
                    -- Fly up and away
                    local away = (hrp.Position - murderer.Position).Unit * 30
                    flyTo(hrp.Position + away + Vector3.new(0, 20, 0), dt)
                    continue
                end
            end
        end

        -- Scan for coins periodically
        if tick() - lastScan > CONFIG.ScanInterval then
            scanCoins()
            lastScan = tick()
            if #coinQueue > 0 then
                log("Found", #coinQueue, "coins.")
            end
        end

        -- Acquire target
        if not currentTarget or not currentTarget.Parent or blacklist[currentTarget] then
            currentTarget = coinQueue[1]
            stuckTick = tick()
            lastPos = currentTarget and currentTarget.Position or nil
        end

        if not currentTarget then
            continue
        end

        -- Stuck detection
        if lastPos and (lastPos - currentTarget.Position).Magnitude < 0.1 then
            if tick() - stuckTick > CONFIG.StuckTimeout then
                log("Coin stuck, blacklisting.")
                blacklist[currentTarget] = true
                task.delay(10, function() blacklist[currentTarget] = nil end)
                currentTarget = nil
                continue
            end
        else
            lastPos = currentTarget.Position
            stuckTick = tick()
        end

        -- Move
        local reached = flyTo(currentTarget.Position, dt)

        if reached then
            -- Touch logic
            pcall(function()
                hrp.CFrame = CFrame.new(currentTarget.Position)
                if firetouchinterest then
                    firetouchinterest(hrp, currentTarget, 0)
                    task.wait()
                    firetouchinterest(hrp, currentTarget, 1)
                end
            end)

            -- Re-check bag immediately after touch
            task.wait(0.1)
            updateBagInfo()

            blacklist[currentTarget] = true
            task.delay(8, function() blacklist[currentTarget] = nil end)

            table.remove(coinQueue, 1)
            currentTarget = nil
            log("Coin collected! Count:", currentCoins .. "/" .. maxBag)
        end
    end

    log("Collector loop ended.")
    cleanup()
end

-- START FUNCTION
local function startCollector()
    if isRunning then
        log("Already running.")
        return
    end

    log("Starting collector...")
    local char, hrp, hum = getCharacterParts()
    if not char then
        warn("[MM2 Collector] No character found! Wait until you spawn.")
        return
    end
    if not hrp then
        warn("[MM2 Collector] HumanoidRootPart not loaded yet. Try again in 2 seconds.")
        return
    end

    cleanup()
    isRunning = true
    blacklist = {}
    coinQueue = {}

    -- Initial bag read
    updateBagInfo()
    log("Current bag:", currentCoins .. "/" .. maxBag)

    enableNoclip()
    task.spawn(collectorLoop)
end

-- TOGGLE KEY (RightShift) - Force start/stop anytime
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        if isRunning then
            log("Manual stop triggered.")
            isRunning = false
            cleanup()
        else
            startCollector()
        end
    end
end)

-- AUTO-START LOGIC
local function tryAutoStart()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        log("Auto-starting...")
        startCollector()
    else
        log("Waiting for character...")
    end
end

-- If already in game
if player.Character then
    task.delay(2, tryAutoStart)
end

-- On respawn
player.CharacterAdded:Connect(function()
    log("Character added, waiting 3 seconds to start...")
    task.delay(3, function()
        if not isRunning then
            tryAutoStart()
        end
    end)
end)

-- Stop on death/reset
player.CharacterRemoving:Connect(function()
    if isRunning then
        log("Character removing, stopping collector.")
        isRunning = false
        cleanup()
    end
end)

log("Script loaded. Press RIGHT SHIFT to toggle, or wait for auto-start.")
