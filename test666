    MinimizeButton.Position = UDim2.new(1, -60, 0.5, -12.5)
    MinimizeButton.Text = "-"
    MinimizeButton.BackgroundColor3 = CONFIG.MinimizeButtonBaseColor
    MinimizeButton.Parent = TitleBar

    local TabBar = Instance.new("Frame")
