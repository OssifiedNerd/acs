-- [[ UTILITY & INTERNAL SENSORS ]]
function MultiGrinder:getHumanoidRootPart()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

function MultiGrinder:getTargetNames(mode)
    local targetString = (mode == "Combat") and self.CombatTargetNames or self.MiningTargetNames
    local names = {}
    for name in string.gmatch(targetString, "[^,]+") do
        names[#names + 1] = name:gsub("^%s*(.-)%s*$", "%1")
    end
    return names
end

function MultiGrinder:findClosestTarget(position, names)
    local closestTargetPart = nil 
    local closestTargetKey = nil 
    local minDistance = math.huge

    for _, obj in ipairs(Workspace:GetDescendants()) do
        for _, name in ipairs(names) do
            if string.lower(obj.Name) == string.lower(name) then 
                local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChild("HumanoidRootPart")
                local targetKey = nil
                
                if targetPart then 
                    local parentModel = targetPart.Parent
                    local humanoid = parentModel:FindFirstChildOfClass("Humanoid")
                    targetKey = humanoid and parentModel or targetPart
                end

                if targetPart and targetKey and targetPart.Position and targetPart.Parent ~= LocalPlayer.Character then
                    if self.IgnoredTargets[targetKey] then continue end
                    local dist = (targetPart.Position - position).Magnitude
                    if dist < minDistance then
                        minDistance = dist
                        closestTargetPart = targetPart 
                        closestTargetKey = targetKey 
                    end
                end
            end
        end
    end
    return closestTargetPart, closestTargetKey
end

-- [[ SCANNING LOGIC - PRIORITY AREAS ]]
function MultiGrinder:findClosestMobInArea(position, radius)
    local closestTargetPart = nil
    local closestTargetKey = nil
    local minDistance = math.huge

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Humanoid") and obj.Health > 0 then
            local parentModel = obj.Parent
            if parentModel and parentModel ~= LocalPlayer.Character then
                local hrp = parentModel:FindFirstChild("HumanoidRootPart")
                if hrp and hrp.Position then
                    if self.IgnoredTargets[parentModel] then continue end
                    local dist = (hrp.Position - position).Magnitude
                    if dist <= radius and dist < minDistance then
                        minDistance = dist
                        closestTargetPart = hrp
                        closestTargetKey = parentModel
                    end
                end
            end
        end
    end
    return closestTargetPart, closestTargetKey
end

function MultiGrinder:findClosestResourceInArea(position, radius, names)
    local closestTargetPart = nil
    local closestTargetKey = nil
    local minDistance = math.huge

    for _, obj in ipairs(Workspace:GetDescendants()) do
        for _, name in ipairs(names) do
            if string.lower(obj.Name) == string.lower(name) then 
                local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChild("HumanoidRootPart")
                if targetPart and not obj:FindFirstChildOfClass("Humanoid") and not obj.Parent:FindFirstChildOfClass("Humanoid") then
                    if self.IgnoredTargets[targetPart] then continue end
                    local dist = (targetPart.Position - position).Magnitude
                    if dist <= radius and dist < minDistance then
                        minDistance = dist
                        closestTargetPart = targetPart
                        closestTargetKey = targetPart
                    end
                end
            end
        end
    end
    return closestTargetPart, closestTargetKey
end

-- [[ FIXED EQUIPMENT LOGIC ]]
function MultiGrinder:equipTool(toolName)
    local char = LocalPlayer.Character
    if not char or not self.Remotes.EquipItem then return false end
    
    local toolInChar = char:FindFirstChild(toolName)
    if toolInChar then return true end

    -- Using the exact snippet provided by user for functional compatibility
    local args = { [1] = toolName }
    local success = pcall(function()
        self.Remotes.EquipItem:InvokeServer(unpack(args))
    end)
    
    if success then
        local found = char:WaitForChild(toolName, 1.5)
        if found then
            self.EquippedToolName = toolName
            return true
        end
    end
    warn("[Multi-Bot Debug] Failed to equip: " .. toolName)
    return false
end

function MultiGrinder:simulateAction(toolName)
    local char = LocalPlayer.Character
    if not char or not self.Remotes.UseItem then return end
    local toolInstance = char:FindFirstChild(toolName)
    if toolInstance then
        self.Remotes.UseItem:FireServer(toolInstance, false)
    end
end

local function restoreCamera(self)
    if self.OriginalCameraCFrame then 
        Camera.CFrame = self.OriginalCameraCFrame 
        self.OriginalCameraCFrame = nil 
    end
end

-- [[ AUTOMATION EXECUTION - COMBAT ]]
function MultiGrinder:executePriorityAreaCombat(hrp)
    local currentAreaCFrame = self.PriorityAreas[self.CurrentPriorityAreaIndex]
    if not currentAreaCFrame then self.CurrentPriorityAreaIndex = 1 return false end

    hrp.CFrame = currentAreaCFrame
    local target = self.PriorityAreaTarget
    local targetIsValid = target and target.Parent and target.Parent:FindFirstChildOfClass("Humanoid") and target.Parent:FindFirstChildOfClass("Humanoid").Health > 0
    
    if not targetIsValid then
        local newTarget, newTargetKey = self:findClosestMobInArea(hrp.Position, self.CombatPriorityAreaScanRadius)
        if newTarget then
            self.PriorityAreaTarget = newTarget
            self.CurrentTargetIdentifier = newTargetKey 
            self.PriorityAreaScanTimer = 0 
            self:updateGUI()
        else
            self.PriorityAreaScanTimer = self.PriorityAreaScanTimer + CONFIG.FarmSpeed
            if self.PriorityAreaScanTimer >= self.CombatPriorityAreaScanTime then
                self.PriorityAreaScanTimer = 0
                self.CurrentPriorityAreaIndex = (self.CurrentPriorityAreaIndex % #self.PriorityAreas) + 1
                self:updateGUI()
            end
            restoreCamera(self)
            return false
        end
    end

    if self:equipTool(self.CombatToolName) then
        local targetPos = self.PriorityAreaTarget.Position + CONFIG.Combat.TeleportOffset
        hrp.CFrame = CFrame.new(targetPos)
        if not self.OriginalCameraCFrame then self.OriginalCameraCFrame = Camera.CFrame end
        Camera.CFrame = CFrame.new(Camera.CFrame.p, self.PriorityAreaTarget.Position)
        self:simulateAction(self.CombatToolName)
    end
    return true
end

function MultiGrinder:executeCombatAction(hrp)
    if self.PriorityAreaEnabled and #self.PriorityAreas > 0 then
        return self:executePriorityAreaCombat(hrp)
    end
    
    local target = self.CurrentTarget
    local needsNewTarget = not target or not target.Parent or not target.Parent:FindFirstChildOfClass("Humanoid") or target.Parent:FindFirstChildOfClass("Humanoid").Health <= 0
    
    if needsNewTarget then
        local newTarget, newTargetKey = self:findClosestTarget(hrp.Position, self:getTargetNames("Combat"))
        if not newTarget then restoreCamera(self) return false end
        self.CurrentTarget = newTarget
        self.CurrentTargetIdentifier = newTargetKey 
        self.TargetAcquiredTime = os.clock() 
        self:updateGUI() 
    end
    
    if self.AutoIgnoreEnabled and self.TargetAcquiredTime and (os.clock() - self.TargetAcquiredTime > 10) then
        if self.CurrentTargetIdentifier then self.IgnoredTargets[self.CurrentTargetIdentifier] = true end
        self.CurrentTarget = nil
        restoreCamera(self)
        return false
    end
    
    if self:equipTool(self.CombatToolName) then
        hrp.CFrame = CFrame.new(self.CurrentTarget.Position + CONFIG.Combat.TeleportOffset)
        if not self.OriginalCameraCFrame then self.OriginalCameraCFrame = Camera.CFrame end
        Camera.CFrame = CFrame.new(Camera.CFrame.p, self.CurrentTarget.Position)
        self:simulateAction(self.CombatToolName)
    end
    return true
end

-- [[ AUTOMATION EXECUTION - MINING ]]
function MultiGrinder:executePriorityAreaMining(hrp)
    local currentAreaCFrame = self.MiningPriorityAreas[self.CurrentMiningPriorityAreaIndex]
    if not currentAreaCFrame then self.CurrentMiningPriorityAreaIndex = 1 return false end

    hrp.CFrame = currentAreaCFrame
    local target = self.MiningPriorityAreaTarget
    if not target or not target.Parent then
        local names = self:getTargetNames("Mining")
        local newTarget, newTargetKey = self:findClosestResourceInArea(hrp.Position, self.MiningPriorityAreaScanRadius, names)
        if newTarget then
            self.MiningPriorityAreaTarget = newTarget
            self.CurrentTargetIdentifier = newTargetKey
            self.MiningPriorityAreaScanTimer = 0
            self:updateGUI()
        else
            self.MiningPriorityAreaScanTimer = self.MiningPriorityAreaScanTimer + CONFIG.FarmSpeed
            if self.MiningPriorityAreaScanTimer >= self.MiningPriorityAreaScanTime then
                self.MiningPriorityAreaScanTimer = 0
                self.CurrentMiningPriorityAreaIndex = (self.CurrentMiningPriorityAreaIndex % #self.MiningPriorityAreas) + 1
                self:updateGUI()
            end
            restoreCamera(self)
            return false
        end
    end

    if self:equipTool(self.MiningToolName) then
        hrp.CFrame = CFrame.new(self.MiningPriorityAreaTarget.Position + CONFIG.Mining.TeleportOffset)
        if not self.OriginalCameraCFrame then self.OriginalCameraCFrame = Camera.CFrame end
        Camera.CFrame = CFrame.new(Camera.CFrame.p, self.MiningPriorityAreaTarget.Position)
        self:simulateAction(self.MiningToolName)
    end
    return true
end

function MultiGrinder:executeMiningAction(hrp)
    if self.MiningPriorityAreaEnabled and #self.MiningPriorityAreas > 0 then
        return self:executePriorityAreaMining(hrp)
    end

    local resource = self.CurrentTarget
    if not resource or not resource.Parent then
        local newResource, newResourceKey = self:findClosestTarget(hrp.Position, self:getTargetNames("Mining"))
        if not newResource then restoreCamera(self) return false end
        self.CurrentTarget = newResource
        self.CurrentTargetIdentifier = newResourceKey 
        self:updateGUI() 
    end
    
    if self:equipTool(self.MiningToolName) then
        hrp.CFrame = CFrame.new(self.CurrentTarget.Position + CONFIG.Mining.TeleportOffset)
        if not self.OriginalCameraCFrame then self.OriginalCameraCFrame = Camera.CFrame end
        Camera.CFrame = CFrame.new(Camera.CFrame.p, self.CurrentTarget.Position)
        self:simulateAction(self.MiningToolName)
    end
    return true
end

-- [[ DATA PERSISTENCE ]]
function MultiGrinder:SaveSettings()
    local settings = {
        CombatToolName = self.CombatToolName, CombatTargetNames = self.CombatTargetNames,
        CombatPriorityAreaScanRadius = self.CombatPriorityAreaScanRadius, CombatPriorityAreaScanTime = self.CombatPriorityAreaScanTime,
        PriorityAreaEnabled = self.PriorityAreaEnabled, MiningToolName = self.MiningToolName,
        MiningTargetNames = self.MiningTargetNames, MiningPriorityAreaScanRadius = self.MiningPriorityAreaScanRadius,
        MiningPriorityAreaScanTime = self.MiningPriorityAreaScanTime, MiningPriorityAreaEnabled = self.MiningPriorityAreaEnabled,
        AutoIgnoreEnabled = self.AutoIgnoreEnabled, TeleportOnRespawnEnabled = self.TeleportOnRespawnEnabled, AutoBlockEnabled = self.AutoBlockEnabled,
        PriorityAreas = {}, MiningPriorityAreas = {}, UIPos = {}
    }
    for _, cf in ipairs(self.PriorityAreas) do table.insert(settings.PriorityAreas, {cf:GetComponents()}) end
    for _, cf in ipairs(self.MiningPriorityAreas) do table.insert(settings.MiningPriorityAreas, {cf:GetComponents()}) end
    if self.MainGui and self.MainGui.MainFrame then
        local pos = self.MainGui.MainFrame.Position
        settings.UIPos = {XScale = pos.X.Scale, XOffset = pos.X.Offset, YScale = pos.Y.Scale, YOffset = pos.Y.Offset}
    end
    local success, result = pcall(self.HttpService.JSONEncode, self.HttpService, settings)
    if success then writefile(self.SettingsFile, result) end
end

function MultiGrinder:LoadSettings()
    if not isfile(self.SettingsFile) then return end
    local success, jsonData = pcall(readfile, self.SettingsFile)
    if not success then return end
    local s, settings = pcall(self.HttpService.JSONDecode, self.HttpService, jsonData)
    if not s or typeof(settings) ~= "table" then return end
    self.CombatToolName = settings.CombatToolName or self.CombatToolName
    self.CombatTargetNames = settings.CombatTargetNames or self.CombatTargetNames
    self.CombatPriorityAreaScanRadius = settings.CombatPriorityAreaScanRadius or self.CombatPriorityAreaScanRadius
    self.CombatPriorityAreaScanTime = settings.CombatPriorityAreaScanTime or self.CombatPriorityAreaScanTime
    self.PriorityAreaEnabled = settings.PriorityAreaEnabled or false
    self.MiningToolName = settings.MiningToolName or self.MiningToolName
    self.MiningTargetNames = settings.MiningTargetNames or self.MiningTargetNames
    self.MiningPriorityAreaScanRadius = settings.MiningPriorityAreaScanRadius or self.MiningPriorityAreaScanRadius
    self.MiningPriorityAreaScanTime = settings.MiningPriorityAreaScanTime or self.MiningPriorityAreaScanTime
    self.MiningPriorityAreaEnabled = settings.MiningPriorityAreaEnabled or false
    self.AutoIgnoreEnabled = settings.AutoIgnoreEnabled or false
    self.TeleportOnRespawnEnabled = settings.TeleportOnRespawnEnabled or false
    self.AutoBlockEnabled = settings.AutoBlockEnabled or false
    if settings.PriorityAreas then
        self.PriorityAreas = {}
        for _, comp in ipairs(settings.PriorityAreas) do table.insert(self.PriorityAreas, CFrame.new(unpack(comp))) end
    end
    if settings.MiningPriorityAreas then
        self.MiningPriorityAreas = {}
        for _, comp in ipairs(settings.MiningPriorityAreas) do table.insert(self.MiningPriorityAreas, CFrame.new(unpack(comp))) end
    end
    if settings.UIPos then
        self.UIPosition = UDim2.new(settings.UIPos.XScale, settings.UIPos.XOffset, settings.UIPos.YScale, settings.UIPos.YOffset)
    end
end

function MultiGrinder:ResetSettings()
    pcall(delfile, self.SettingsFile)
    print("Settings reset. Please restart script.")
end

-- [[ GUI FRAMEWORK & FIXED INTERACTION ]]
function MultiGrinder:setMinimizedState(isMinimized)
    self.IsMinimized = isMinimized
    if not self.MainGui then return end
    local MainFrame = self.MainGui.MainFrame
    local ContentContainer = MainFrame:FindFirstChild("ContentContainer")
    local TabBar = MainFrame:FindFirstChild("TabBar")
    
    if ContentContainer then ContentContainer.Visible = not isMinimized end
    if TabBar then TabBar.Visible = not isMinimized end
    
    if isMinimized then
        MainFrame:TweenSize(UDim2.new(0, CONFIG.FrameWidth, 0, CONFIG.TitleBarHeight), "Out", "Quad", 0.2, true)
        self.MainGui.MinimizeButton.Text = "+" 
    else
        MainFrame:TweenSize(UDim2.new(0, CONFIG.FrameWidth, 0, self.InitialFrameHeight), "Out", "Quad", 0.2, true)
        self.MainGui.MinimizeButton.Text = "-" 
    end
end

function MultiGrinder:updateGUI()
    if not self.MainGui then return end
    local GP = self.MainGui.GeneralPage
    GP.ToggleButton.Text = self.Enabled and "ON" or "OFF"
    GP.ToggleButton.BackgroundColor3 = self.Enabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    GP.AutoIgnoreButton.BackgroundColor3 = self.AutoIgnoreEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    GP.TeleportOnRespawnButton.BackgroundColor3 = self.TeleportOnRespawnEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    GP.AutoBlockButton.BackgroundColor3 = self.AutoBlockEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    GP.ModeButton.Text = self.Mode .. " (" .. (self.Mode == "Combat" and self.CombatToolName or self.MiningToolName) .. ")"
    
    self.MainGui.CombatPage.PriorityAreaToggleButton.BackgroundColor3 = self.PriorityAreaEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    self.MainGui.CombatPage.PriorityAreaCountLabel.Text = "Areas: " .. #self.PriorityAreas .. "/20"
    
    self.MainGui.MiningPage.MiningPriorityAreaToggleButton.BackgroundColor3 = self.MiningPriorityAreaEnabled and CONFIG.ToggleOnColor or CONFIG.ToggleOffColor
    self.MainGui.MiningPage.MiningPriorityAreaCountLabel.Text = "Areas: " .. #self.MiningPriorityAreas .. "/20"
end

function MultiGrinder:showTab(tabName)
    self.CurrentTab = tabName
    for name, page in pairs(self.MainGui.Pages) do page.Visible = (name == tabName) end
    self:updateGUI()
end

function MultiGrinder:setupGUI()
