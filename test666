-- [[ REMOTE HANDLING - UPDATED PATHS ]]
local function getRemotes()
    -- Path provided by user for working equipment
    local clientRemotes = ReplicatedStorage:WaitForChild("ClientRemotes", 5)
    local inventory = clientRemotes and clientRemotes:WaitForChild("Inventory", 5)
    local workspaceRemotes = Workspace:FindFirstChild("Remotes")
    
    local remotes = {}
    
    -- Crucial Fix: Use the specific path for EquipItem as requested
    if inventory then
        remotes.EquipItem = inventory:FindFirstChild("EquipItem")
    end
    
    remotes.UseItem = (workspaceRemotes and workspaceRemotes:FindFirstChild("UseItem")) or (clientRemotes and clientRemotes:FindFirstChild("UseItem"))
    remotes.Block = (workspaceRemotes and workspaceRemotes:FindFirstChild("Block")) or (clientRemotes and clientRemotes:FindFirstChild("Block"))

    if remotes.EquipItem then
        print("[Multi-Bot Debug] Remote EquipItem FOUND in Inventory.")
    else
        warn("[Multi-Bot Debug] Remote: CRITICAL - EquipItem remote not found at ReplicatedStorage.ClientRemotes.Inventory.EquipItem")
    end
    
    return remotes
end

