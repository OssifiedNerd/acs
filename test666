--[[
    MM2 Coin Collector - Tween Edition + Auto Bag Scanner
    Press RIGHT SHIFT to toggle.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- CONFIGURATION
local CONFIG = {
    CoinName = "Coin_Server",        -- Change if your executor shows a different coin name
    FlySpeed = 20,                   -- Studs per second (tween glide speed)
    CollectionRadius = 2.5,
    SafeMode = true,
    SafeDistance = 50,
    NoclipTransparency = 0.35,
    ScanInterval = 0.5,
    DebugPrints = true,
}

-- STATE
local isRunning = false
local connections = {}
local coinQueue = {}
local blacklist = {}
local currentTarget = nil
local maxBag = 40
local currentCoins = 0
local activeTween = nil
local bagLabel = nil                  -- Cached UI label

-- UTILITIES
local function log(...)
    if CONFIG.DebugPrints then
        print("[MM2 Collector]", ...)
    end
end

local function cleanup()
    isRunning = false
    if activeTween then
        pcall(function() activeTween:Cancel() end)
        activeTween = nil
    end
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    currentTarget = nil
    coinQueue = {}
    bagLabel = nil
end

local function getCharacterParts()
    local char = player.Character
    if not char then return nil, nil, nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if hrp and hum then return char, hrp, hum end
    return nil, nil, nil
end

-- UNIVERSAL BAG SCANNER: Searches ALL PlayerGui descendants for "12 / 40" or "12/40"
local function findBagUI()
    if bagLabel and bagLabel.Parent then
        return bagLabel
    end
    
    local pg = player:FindFirstChild("PlayerGui")
    if not pg then return nil end
    
    for _, gui in ipairs(pg:GetDescendants()) do
        if gui:IsA("TextLabel") or gui:IsA("TextButton") then
            local text = gui.Text
            -- Matches: "5/40", "5 / 40", "Bag: 5 / 40", "Coins 12/50", etc.
            local cur, max = text:match("(%d+)%s*/%s*(%d+)")
            if cur and max then
                bagLabel = gui
                return gui
            end
        end
    end
    return nil
end

local function updateBagInfo()
    local label = findBagUI()
    if label then
        local text = label.Text
        local cur, max = text:match("(%d+)%s*/%s*(%d+)")
        if cur and max then
            currentCoins = tonumber(cur)
            local newMax = tonumber(max)
            if newMax and newMax ~= maxBag then
                maxBag = newMax
                log("Detected bag capacity:", maxBag)
            end
        end
    end
end

-- MURDERER DETECTION
local function getMurdererHRP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        local pData = plr:FindFirstChild("PlayerData")
        if pData then
            local role = pData:FindFirstChild("Role")
            if role and role:IsA("ValueBase") and role.Value == "Murderer" then
                local char = plr.Character
                if char then return char:FindFirstChild("HumanoidRootPart") end
            end
        end
    end
    return nil
end

-- NOCLIP
local function enableNoclip()
    local conn = RunService.Stepped:Connect(function()
        local char = player.Character
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
                if part.Name ~= "HumanoidRootPart" then
                    part.LocalTransparencyModifier = CONFIG.NoclipTransparency
                end
            end
        end
    end)
    table.insert(connections, conn)
    log("Noclip enabled.")
end

-- COIN SCANNER
local function scanCoins()
    local char, hrp = getCharacterParts()
    if not hrp then return end

    local found = {}
    local myPos = hrp.Position
    local searchRoot = Workspace:FindFirstChild("Normal")
    
    if searchRoot then
        local cc = searchRoot:FindFirstChild("CoinContainer")
        if cc then searchRoot = cc end
    else
        searchRoot = Workspace
    end

    for _, obj in ipairs(searchRoot:GetDescendants()) do
        if obj.Name == CONFIG.CoinName and obj:IsA("BasePart") and obj.Parent then
            if not blacklist[obj] then
                table.insert(found, {
                    Obj = obj,
                    Dist = (myPos - obj.Position).Magnitude
                })
            end
        end
    end

    table.sort(found, function(a, b) return a.Dist < b.Dist end)
    
    coinQueue = {}
    for _, data in ipairs(found) do
        table.insert(coinQueue, data.Obj)
    end
end

-- TWEEN MOVEMENT ENGINE
local function tweenToCoin(target, onComplete)
    local char, hrp, hum = getCharacterParts()
    if not hrp then
        onComplete(false)
        return
    end

    -- Cancel any existing tween
    if activeTween then
        pcall(function() activeTween:Cancel() end)
        activeTween = nil
    end

    local startPos = hrp.Position
    local endPos = target.Position
    local distance = (endPos - startPos).Magnitude
    
    if distance <= CONFIG.CollectionRadius then
        onComplete(true)
        return
    end

    local duration = distance / CONFIG.FlySpeed
    if duration < 0.05 then duration = 0.05 end

    local direction = (endPos - startPos).Unit
    local lookCFrame = CFrame.new(endPos, endPos + direction)

    local tweenInfo = TweenInfo.new(
        duration,
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.Out
    )

    activeTween = TweenService:Create(hrp, tweenInfo, {CFrame = lookCFrame})
    
    activeTween.Completed:Connect(function(status)
        activeTween = nil
        onComplete(status == Enum.PlaybackState.Completed)
    end)
    
    activeTween:Play()
end

-- RESET
local function resetCharacter()
    log("Bag full! Resetting...")
    isRunning = false
    cleanup()

    task.spawn(function()
        for _ = 1, 6 do
            local _, hrp, hum = getCharacterParts()
            if hrp then
                pcall(function()
                    hrp.CFrame = CFrame.new(hrp.Position.X, -500, hrp.Position.Z)
                    hrp.AssemblyLinearVelocity = Vector3.new(0, -400, 0)
                end)
            end
            if hum then
                pcall(function() hum.Health = 0 end)
            end
            task.wait(0.12)
        end
    end)
end

-- MAIN LOOP
local function collectorLoop()
    log("Loop started.")
    local lastScan = 0
    local tweenDone = false
    local tweenSuccess = false

    while isRunning do
        task.wait(0.05)

        local char, hrp, hum = getCharacterParts()
        if not char or not hrp or not hum or hum.Health <= 0 then
            log("Character dead/missing.")
            break
        end

        -- Zero velocity so gravity doesn't fight the tween
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero

        -- Update bag info continuously
        updateBagInfo()

        -- Auto-detected full bag
        if currentCoins >= maxBag then
            log(string.format("Bag FULL! %d/%d", currentCoins, maxBag))
            resetCharacter()
            return
        end

        -- Safe mode murderer check
        if CONFIG.SafeMode then
            local murderer = getMurdererHRP()
            if murderer then
                local dist = (hrp.Position - murderer.Position).Magnitude
                if dist < CONFIG.SafeDistance then
                    if activeTween then
                        pcall(function() activeTween:Cancel() end)
                        activeTween = nil
                    end
                    -- Glide away from murderer
                    local away = (hrp.Position - murderer.Position).Unit * 40
                    local safePos = hrp.Position + away + Vector3.new(0, 15, 0)
                    hrp.CFrame = CFrame.new(safePos, safePos + away)
                    continue
                end
            end
        end

        -- Scan periodically
        if tick() - lastScan > CONFIG.ScanInterval then
            scanCoins()
            lastScan = tick()
            if #coinQueue > 0 then
                log("Found", #coinQueue, "coins | Bag:", currentCoins .. "/" .. maxBag)
            end
        end

        -- Pick new target if needed
        if not currentTarget or not currentTarget.Parent or blacklist[currentTarget] then
            currentTarget = coinQueue[1]
        end

        if not currentTarget then
            continue
        end

        -- Tween to coin
        tweenDone = false
        tweenSuccess = false

        tweenToCoin(currentTarget, function(success)
            tweenDone = true
            tweenSuccess = success
        end)

        -- Wait for tween while checking conditions
        while not tweenDone and isRunning do
            task.wait(0.05)

            -- Re-check bag mid-flight
            updateBagInfo()
            if currentCoins >= maxBag then
                if activeTween then pcall(function() activeTween:Cancel() end) end
                activeTween = nil
                resetCharacter()
                return
            end

            -- Re-check murderer mid-flight
            if CONFIG.SafeMode then
                local murderer = getMurdererHRP()
                if murderer then
                    local char2, hrp2 = getCharacterParts()
                    if hrp2 and (hrp2.Position - murderer.Position).Magnitude < CONFIG.SafeDistance then
                        if activeTween then pcall(function() activeTween:Cancel() end) end
                        activeTween = nil
                        tweenDone = true
                        tweenSuccess = false
                        break
                    end
                end
            end

            -- Target disappeared?
            if not currentTarget or not currentTarget.Parent then
                if activeTween then pcall(function() activeTween:Cancel() end) end
                activeTween = nil
                tweenDone = true
                tweenSuccess = false
                break
            end
        end

        -- Collection
        if tweenSuccess and currentTarget and currentTarget.Parent then
            -- Snap to exact position and touch
            pcall(function()
                hrp.CFrame = CFrame.new(currentTarget.Position)
                if firetouchinterest then
                    firetouchinterest(hrp, currentTarget, 0)
                    task.wait()
                    firetouchinterest(hrp, currentTarget, 1)
                end
            end)

            task.wait(0.1)
            updateBagInfo()

            log(string.format("Collected! Bag: %d/%d", currentCoins, maxBag))

            blacklist[currentTarget] = true
            task.delay(10, function() blacklist[currentTarget] = nil end)

            table.remove(coinQueue, 1)
            currentTarget = nil
        elseif not tweenSuccess then
            -- Tween was cancelled or failed
            if currentTarget then
                blacklist[currentTarget] = true
                task.delay(8, function() blacklist[currentTarget] = nil end)
            end
            currentTarget = nil
        end
    end

    log("Loop ended.")
    cleanup()
end

-- START
local function startCollector()
    if isRunning then return end

    local char, hrp, hum = getCharacterParts()
    if not char then
        warn("[MM2 Collector] No character. Wait until you spawn.")
        return
    end
    if not hrp then
        warn("[MM2 Collector] HRP not loaded yet. Try again in 2s.")
        return
    end

    cleanup()
    isRunning = true
    blacklist = {}
    coinQueue = {}

    updateBagInfo()
    log(string.format("Started. Bag: %d/%d", currentCoins, maxBag))

    enableNoclip()
    task.spawn(collectorLoop)
end

-- RIGHT SHIFT TOGGLE
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        if isRunning then
            log("Manual stop.")
            cleanup()
        else
            startCollector()
        end
    end
end)

-- AUTO START
local function autoStart()
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        task.delay(2, startCollector)
    end
end

player.CharacterAdded:Connect(function()
    log("Respawn detected. Starting in 3s...")
    task.delay(3, function()
        if not isRunning then startCollector() end
    end)
end)

player.CharacterRemoving:Connect(function()
    if isRunning then cleanup() end
end)

autoStart()
log("Loaded. Press RIGHT SHIFT to toggle.")
