function MultiGrinder:getHumanoidRootPart()
return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

function MultiGrinder:getTargetNames(mode)
local targetString = (mode == "Combat") and self.CombatTargetNames or self.MiningTargetNames
local names = {}
for name in string.gmatch(targetString, "[^,]+") do
names[#names + 1] = name:gsub("^%s*(.-)%s*$", "%1")
end
return names
end

function MultiGrinder:findClosestTarget(position, names)
local closestTargetPart, closestTargetKey = nil, nil
local minDistance = math.huge
for _, obj in ipairs(Workspace:GetDescendants()) do
for _, name in ipairs(names) do
if string.lower(obj.Name) == string.lower(name) then
local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChild("HumanoidRootPart")
if targetPart and targetPart.Parent ~= LocalPlayer.Character then
local targetKey = targetPart.Parent:FindFirstChildOfClass("Humanoid") and targetPart.Parent or targetPart
if self.IgnoredTargets[targetKey] then continue end
local dist = (targetPart.Position - position).Magnitude
if dist < minDistance then
minDistance = dist
closestTargetPart = targetPart
closestTargetKey = targetKey
end
end
end
end
end
return closestTargetPart, closestTargetKey
end

-- FIXED EQUIP LOGIC
function MultiGrinder:equipTool(toolName)
local char = LocalPlayer.Character
if not char or not self.Remotes.EquipItem then return false end

local toolInChar = char:FindFirstChild(toolName)
if toolInChar then return true end

-- Invoke the server to equip the item using the specific arguments you provided
local args = { [1] = toolName }
local success = self.Remotes.EquipItem:InvokeServer(unpack(args))

-- Wait briefly for replication
local tool = char:WaitForChild(toolName, 1.5)
if tool then
    self.EquippedToolName = toolName
    return true
end
return false


end

function MultiGrinder:simulateAction(toolName)
local char = LocalPlayer.Character
if not char or not self.Remotes.UseItem then return end
local toolInstance = char:FindFirstChild(toolName) or LocalPlayer.Backpack:FindFirstChild(toolName)
if toolInstance then
self.Remotes.UseItem:FireServer(toolInstance, false)
end
end

local function restoreCamera(self)
if self.OriginalCameraCFrame then
Camera.CFrame = self.OriginalCameraCFrame
self.OriginalCameraCFrame = nil
end
end

-- LOGIC LOOPS
function MultiGrinder:executeCombatAction(hrp)
local char = LocalPlayer.Character
local toolName = self.CombatToolName
local targetNames = self:getTargetNames("Combat")

-- Normal Target Acquisition
if not self.CurrentTarget or not self.CurrentTarget.Parent then
    local nt, nk = self:findClosestTarget(hrp.Position, targetNames)
    self.CurrentTarget = nt
    self.CurrentTargetIdentifier = nk
end

local target = self.CurrentTarget
if not target then restoreCamera(self) return end

-- Check if tool is equipped, if not, equip it
if not char:FindFirstChild(toolName) then
    self:equipTool(toolName)
end

-- Teleport and Attack
hrp.CFrame = CFrame.new(target.Position + CONFIG.Combat.TeleportOffset)
if not self.OriginalCameraCFrame then self.OriginalCameraCFrame = Camera.CFrame end
Camera.CFrame = CFrame.new(target.Position + Vector3.new(0, 10, 0), target.Position)
self:simulateAction(toolName)


end

function MultiGrinder:executeMiningAction(hrp)
local char = LocalPlayer.Character
local toolName = self.MiningToolName
local targetNames = self:getTargetNames("Mining")

if not self.CurrentTarget or not self.CurrentTarget.Parent then
    local nt, nk = self:findClosestTarget(hrp.Position, targetNames)
    self.CurrentTarget = nt
    self.CurrentTargetIdentifier = nk
end

local target = self.CurrentTarget
if not target then restoreCamera(self) return end

if not char:FindFirstChild(toolName) then
    self:equipTool(toolName)
end

hrp.CFrame = CFrame.new(target.Position + CONFIG.Mining.TeleportOffset)
if not self.OriginalCameraCFrame then self.OriginalCameraCFrame = Camera.CFrame end
Camera.CFrame = CFrame.new(target.Position + Vector3.new(0, 10, 0), target.Position)
self:simulateAction(toolName)


end

-- PERSISTENCE
function MultiGrinder:SaveSettings()
local settings = {
CombatToolName = self.CombatToolName,
CombatTargetNames = self.CombatTargetNames,
AutoIgnoreEnabled = self.AutoIgnoreEnabled,
AutoBlockEnabled = self.AutoBlockEnabled,
}
pcall(writefile, self.SettingsFile, HttpService:JSONEncode(settings))
end

function MultiGrinder:LoadSettings()
if isfile(self.SettingsFile) then
local success, data = pcall(function() return HttpService:JSONDecode(readfile(self.SettingsFile)) end)
if success and data then
self.CombatToolName = data.CombatToolName or self.CombatToolName
self.CombatTargetNames = data.CombatTargetNames or self.CombatTargetNames
self.AutoIgnoreEnabled = data.AutoIgnoreEnabled or self.AutoIgnoreEnabled
self.AutoBlockEnabled = data.AutoBlockEnabled or self.AutoBlockEnabled
end
end
end

-- GUI LOGIC
function MultiGrinder:setMinimizedState(isMinimized)
self.IsMinimized = isMinimized
local MainFrame = self.MainGui.MainFrame

-- Toggle visibility of containers
MainFrame.ContentContainer.Visible = not isMinimized
MainFrame.TabBar.Visible = not isMinimized

if isMinimized then
    MainFrame:TweenSize(UDim2.new(0, CONFIG.FrameWidth, 0, CONFIG.TitleBarHeight), "Out", "Quad", 0.2, true)
    self.MainGui.MinimizeButton.Text = "+" 
else
    MainFrame:TweenSize(UDim2.new(0, CONFIG.FrameWidth, 0, self.InitialFrameHeight), "Out", "Quad", 0.2, true)
    self.MainGui.MinimizeButton.Text = "-" 
end


end

