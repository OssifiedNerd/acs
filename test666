local function getRemotes()
-- Path provided by user for Inventory Equip
local clientRemotes = ReplicatedStorage:WaitForChild("ClientRemotes", 5)
local inventoryRemotes = clientRemotes and clientRemotes:WaitForChild("Inventory", 5)
local generalRemotes = Workspace:FindFirstChild("Remotes") or ReplicatedStorage:FindFirstChild("Remotes") or Workspace

local remotes = {}

if inventoryRemotes then
    remotes.EquipItem = inventoryRemotes:WaitForChild("EquipItem", 5) 
end

remotes.UseItem = generalRemotes:WaitForChild("UseItem", 5) 
remotes.Block = generalRemotes:WaitForChild("Block", 5)

if remotes.EquipItem then
    print("[Multi-Bot] EquipItem Remote Connected.")
else
    warn("[Multi-Bot] CRITICAL: EquipItem remote not found at ReplicatedStorage.ClientRemotes.Inventory.EquipItem")
end

return remotes


end

